<!DOCTYPE html>
<html lang="id" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EduHIV - Edukasi & Pencegahan HIV/AIDS</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- FontAwesome CDN -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        brand: {
                            50: '#f0f9ff',
                            500: '#0ea5e9',
                            600: '#0284c7',
                            700: '#0369a1',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        .card-glow {
            box-shadow: 0 0 25px -5px rgba(14, 165, 233, 0.15);
        }
    </style>
</head>
<body class="bg-slate-900 text-slate-100 min-h-screen flex flex-col font-sans antialiased">

    <!-- NAVBAR -->
    <nav class="bg-slate-800/80 backdrop-blur-md border-b border-slate-700 sticky top-0 z-50">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
            <div class="flex items-center gap-3 cursor-pointer" onclick="showSection('home')">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-tr from-cyan-500 to-blue-600 flex items-center justify-center text-white font-bold text-xl shadow-lg shadow-cyan-500/30">
                    <i class="fa-solid fa-ribbon"></i>
                </div>
                <div>
                    <span class="font-extrabold text-lg text-white tracking-wide">Edu<span class="text-cyan-400">HIV</span></span>
                    <span class="text-[10px] block text-slate-400 -mt-1">Edukasi & Informasi Terpercaya</span>
                </div>
            </div>
            
            <div id="nav-user-info" class="hidden items-center gap-3">
                <span id="user-display-name" class="text-sm font-medium text-slate-300"></span>
                <button onclick="logout()" class="text-xs bg-slate-700 hover:bg-slate-600 text-slate-200 px-3 py-1.5 rounded-lg border border-slate-600 transition">
                    <i class="fa-solid fa-right-from-bracket mr-1"></i> Keluar
                </button>
            </div>
        </div>
    </nav>

    <!-- MAIN CONTAINER -->
    <main class="flex-1 max-w-6xl w-full mx-auto p-4 sm:p-6 lg:p-8">

        <!-- SECTION 1: AUTHENTICATION (LOGIN / REGISTER) -->
        <section id="auth-section" class="max-w-md mx-auto my-10 animate-fade-in">
            <div class="bg-slate-800 p-6 sm:p-8 rounded-2xl border border-slate-700 card-glow">
                <div class="text-center mb-6">
                    <h2 id="auth-title" class="text-2xl font-bold text-white mb-1">Selamat Datang</h2>
                    <p id="auth-subtitle" class="text-xs text-slate-400">Masuk untuk mengakses materi edukasi interaktif</p>
                </div>

                <form id="auth-form" onsubmit="handleAuth(event)" class="space-y-4">
                    <div>
                        <label class="block text-xs font-semibold text-slate-300 mb-1">Nama Lengkap</label>
                        <input type="text" id="auth-name" required placeholder="Masukkan nama kamu" class="w-full bg-slate-900 border border-slate-700 rounded-xl px-4 py-2.5 text-sm text-white focus:outline-none focus:border-cyan-500 transition">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-300 mb-1">Password</label>
                        <input type="password" id="auth-pass" required placeholder="••••••••" class="w-full bg-slate-900 border border-slate-700 rounded-xl px-4 py-2.5 text-sm text-white focus:outline-none focus:border-cyan-500 transition">
                    </div>
                    <button type="submit" id="auth-btn" class="w-full bg-gradient-to-r from-cyan-500 to-blue-600 hover:from-cyan-400 hover:to-blue-500 text-white font-semibold py-2.5 rounded-xl text-sm transition duration-300 shadow-lg shadow-cyan-500/25 mt-2">
                        Masuk Sekarang
                    </button>
                </form>

                <div class="mt-6 text-center text-xs text-slate-400">
                    <span id="auth-toggle-text">Belum punya akun?</span>
                    <button type="button" onclick="toggleAuthMode()" id="auth-toggle-btn" class="text-cyan-400 font-semibold hover:underline ml-1">Daftar</button>
                </div>
            </div>
        </section>

        <!-- SECTION 2: HOME / DASHBOARD (MENU UTAMA) -->
        <section id="home-section" class="hidden space-y-8 animate-fade-in">
            <!-- Hero Banner -->
            <div class="bg-gradient-to-r from-slate-800 via-slate-800 to-slate-800/80 p-6 sm:p-8 rounded-3xl border border-slate-700 relative overflow-hidden">
                <div class="relative z-10 max-w-2xl">
                    <span class="text-xs font-semibold text-cyan-400 tracking-wider uppercase bg-cyan-500/10 border border-cyan-500/20 px-3 py-1 rounded-full mb-3 inline-block">Platform Edukasi Digital</span>
                    <h1 class="text-2xl sm:text-3xl font-extrabold text-white mb-3">Pahami HIV/AIDS dengan Informasi yang Tepat</h1>
                    <p class="text-xs sm:text-sm text-slate-300 leading-relaxed mb-6">Hilangkan stikmatisasi dengan pengetahuan factual. Pelajari cara penularan, pencegahan, kuis interaktif, hingga peta lokasi layanan kesehatan terdekat.</p>
                    <button onclick="showSection('belajar')" class="bg-cyan-500 hover:bg-cyan-400 text-slate-950 font-bold px-5 py-2.5 rounded-xl text-xs sm:text-sm transition flex items-center gap-2">
                        <span>Mulai Pelajari Sekarang</span>
                        <i class="fa-solid fa-arrow-right"></i>
                    </button>
                </div>
            </div>

            <!-- GRID MENU UTAMA (TANPA STATISTIK) -->
            <div>
                <h3 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-4">Fitur Utama</h3>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                    
                    <!-- Card 1: Mulai Belajar -->
                    <button onclick="showSection('belajar')" class="p-5 text-left bg-slate-800 hover:bg-slate-700/80 rounded-2xl border border-slate-700 transition duration-300 group">
                        <div class="w-12 h-12 rounded-xl bg-cyan-500/10 flex items-center justify-center text-cyan-400 text-xl mb-4 group-hover:scale-110 transition">
                            <i class="fa-solid fa-book-open"></i>
                        </div>
                        <h4 class="font-bold text-white mb-1">Mulai Belajar</h4>
                        <p class="text-xs text-slate-400">Materi dasar HIV/AIDS, tahapan infeksi, dan metode pencegahan.</p>
                    </button>

                    <!-- Card 2: Mitos vs Fakta -->
                    <button onclick="showSection('fakta')" class="p-5 text-left bg-slate-800 hover:bg-slate-700/80 rounded-2xl border border-slate-700 transition duration-300 group">
                        <div class="w-12 h-12 rounded-xl bg-purple-500/10 flex items-center justify-center text-purple-400 text-xl mb-4 group-hover:scale-110 transition">
                            <i class="fa-solid fa-lightbulb"></i>
                        </div>
                        <h4 class="font-bold text-white mb-1">Mitos vs Fakta</h4>
                        <p class="text-xs text-slate-400">Luruskan persepsi keliru yang beredar di tengah masyarakat.</p>
                    </button>

                    <!-- Card 3: Kuis Edukasi -->
                    <button onclick="showSection('quiz')" class="p-5 text-left bg-slate-800 hover:bg-slate-700/80 rounded-2xl border border-slate-700 transition duration-300 group">
                        <div class="w-12 h-12 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-400 text-xl mb-4 group-hover:scale-110 transition">
                            <i class="fa-solid fa-graduation-cap"></i>
                        </div>
                        <h4 class="font-bold text-white mb-1">Kuis Edukasi</h4>
                        <p class="text-xs text-slate-400">Uji sejauh mana pemahamanmu tentang HIV/AIDS secara interaktif.</p>
                    </button>

                    <!-- Card 4: Tes VCT & Layanan -->
                    <button onclick="showSection('vct')" class="p-5 text-left bg-slate-800 hover:bg-slate-700/80 rounded-2xl border border-slate-700 transition duration-300 group">
                        <div class="w-12 h-12 rounded-xl bg-rose-500/10 flex items-center justify-center text-rose-400 text-xl mb-4 group-hover:scale-110 transition">
                            <i class="fa-solid fa-hospital-user"></i>
                        </div>
                        <h4 class="font-bold text-white mb-1">Peta Layanan VCT</h4>
                        <p class="text-xs text-slate-400">Informasi konseling & lokasi tes terdekat yang rahasia dan aman.</p>
                    </button>

                    <!-- Card 5: Simulasi Risiko -->
                    <button onclick="showSection('simulasi')" class="p-5 text-left bg-slate-800 hover:bg-slate-700/80 rounded-2xl border border-slate-700 transition duration-300 group">
                        <div class="w-12 h-12 rounded-xl bg-amber-500/10 flex items-center justify-center text-amber-400 text-xl mb-4 group-hover:scale-110 transition">
                            <i class="fa-solid fa-calculator"></i>
                        </div>
                        <h4 class="font-bold text-white mb-1">Simulasi Risiko</h4>
                        <p class="text-xs text-slate-400">Cek tingkat risiko aktivitas harian terhadap penularan HIV.</p>
                    </button>

                </div>
            </div>
        </section>

        <!-- SECTION 3: MATERI BELAJAR -->
        <section id="belajar-section" class="hidden space-y-6 animate-fade-in">
            <div class="flex items-center justify-between border-b border-slate-700 pb-4">
                <h2 class="text-xl font-bold text-white flex items-center gap-2">
                    <i class="fa-solid fa-book-open text-cyan-400"></i> Materi Edukasi HIV/AIDS
                </h2>
                <button onclick="showSection('home')" class="text-xs bg-slate-800 hover:bg-slate-700 text-slate-300 px-3 py-1.5 rounded-lg border border-slate-700">
                    <i class="fa-solid fa-arrow-left mr-1"></i> Kembali
                </button>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Card 1 -->
                <div class="bg-slate-800 p-6 rounded-2xl border border-slate-700 space-y-3">
                    <span class="text-xs font-semibold text-cyan-400 uppercase tracking-wider">Dasar Pengetahuan</span>
                    <h3 class="text-lg font-bold text-white">Apa itu HIV & AIDS?</h3>
                    <p class="text-xs text-slate-300 leading-relaxed">
                        <strong class="text-white">HIV (Human Immunodeficiency Virus)</strong> adalah virus yang menyerang sistem kekebalan tubuh, khususnya sel CD4. 
                        <br><br>
                        <strong class="text-white">AIDS (Acquired Immunodeficiency Syndrome)</strong> adalah stadium akhir dari infeksi HIV, di mana tubuh kehilangan kemampuan untuk melawan infeksi.
                    </p>
                </div>

                <!-- Card 2 -->
                <div class="bg-slate-800 p-6 rounded-2xl border border-slate-700 space-y-3">
                    <span class="text-xs font-semibold text-emerald-400 uppercase tracking-wider">Jalur Penularan</span>
                    <h3 class="text-lg font-bold text-white">Bagaimana HIV Menular?</h3>
                    <ul class="text-xs text-slate-300 space-y-2 list-disc list-inside">
                        <li>Hubungan seksual berisiko tanpa pelindung.</li>
                        <li>Penggunaan jarum suntik secara bergantian.</li>
                        <li>Transfusi darah yang tercemar HIV.</li>
                        <li>Penularan dari ibu hamil ke bayi saat persalinan/menyusui.</li>
                    </ul>
                </div>

                <!-- Card 3 -->
                <div class="bg-slate-800 p-6 rounded-2xl border border-slate-700 space-y-3">
                    <span class="text-xs font-semibold text-rose-400 uppercase tracking-wider">Pencegahan</span>
                    <h3 class="text-lg font-bold text-white">Prinsip ABCDE</h3>
                    <ul class="text-xs text-slate-300 space-y-1.5">
                        <li><strong class="text-white">A (Abstinence):</strong> Tidak melakukan hubungan seksual berisiko.</li>
                        <li><strong class="text-white">B (Be Faithful):</strong> Saling setia pada satu pasangan.</li>
                        <li><strong class="text-white">C (Condom):</strong> Gunakan pelindung saat berhubungan.</li>
                        <li><strong class="text-white">D (Don't use drugs):</strong> Hindari pemakaian narkoba suntik.</li>
                        <li><strong class="text-white">E (Education):</strong> Cari informasi tepat & tingkatkan edukasi.</li>
                    </ul>
                </div>

                <!-- Card 4 -->
                <div class="bg-slate-800 p-6 rounded-2xl border border-slate-700 space-y-3">
                    <span class="text-xs font-semibold text-amber-400 uppercase tracking-wider">Pengobatan</span>
                    <h3 class="text-lg font-bold text-white">Pengobatan ARV</h3>
                    <p class="text-xs text-slate-300 leading-relaxed">
                        HIV belum bisa disembuhkan secara total, namun dapat dikendalikan dengan terapi <strong class="text-white">ARV (Antiretroviral)</strong>. 
                        Pengobatan ARV yang teratur memungkinkan orang dengan HIV (ODHIV) hidup sehat dan produktif seperti masyarakat pada umumnya.
                    </p>
                </div>
            </div>
        </section>

        <!-- SECTION 4: MITOS VS FAKTA -->
        <section id="fakta-section" class="hidden space-y-6 animate-fade-in">
            <div class="flex items-center justify-between border-b border-slate-700 pb-4">
                <h2 class="text-xl font-bold text-white flex items-center gap-2">
                    <i class="fa-solid fa-lightbulb text-purple-400"></i> Mitos vs Fakta HIV/AIDS
                </h2>
                <button onclick="showSection('home')" class="text-xs bg-slate-800 hover:bg-slate-700 text-slate-300 px-3 py-1.5 rounded-lg border border-slate-700">
                    <i class="fa-solid fa-arrow-left mr-1"></i> Kembali
                </button>
            </div>

            <div class="space-y-4">
                <!-- Item 1 -->
                <div class="bg-slate-800 p-5 rounded-2xl border border-slate-700 space-y-2">
                    <div class="flex items-center gap-2 text-rose-400 font-bold text-xs uppercase">
                        <i class="fa-solid fa-xmark-circle"></i> Mitos
                    </div>
                    <p class="text-sm font-semibold text-white">"HIV menular lewat jabat tangan, pelukan, atau berbagi alat makan."</p>
                    <div class="flex items-center gap-2 text-emerald-400 font-bold text-xs uppercase pt-2 border-t border-slate-700/60">
                        <i class="fa-solid fa-check-circle"></i> Fakta
                    </div>
                    <p class="text-xs text-slate-300">HIV <strong>TIDAK</strong> menular melalui kontak sosial sehari-hari seperti bersentuhan, air liur, keringat, gigitan nyamuk, atau berbagi alat makan.</p>
                </div>

                <!-- Item 2 -->
                <div class="bg-slate-800 p-5 rounded-2xl border border-slate-700 space-y-2">
                    <div class="flex items-center gap-2 text-rose-400 font-bold text-xs uppercase">
                        <i class="fa-solid fa-xmark-circle"></i> Mitos
                    </div>
                    <p class="text-sm font-semibold text-white">"Orang yang terinfeksi HIV terlihat sangat kurus dan sakit-sakitan."</p>
                    <div class="flex items-center gap-2 text-emerald-400 font-bold text-xs uppercase pt-2 border-t border-slate-700/60">
                        <i class="fa-solid fa-check-circle"></i> Fakta
                    </div>
                    <p class="text-xs text-slate-300">Pada tahap awal (periode jendela), seseorang yang terinfeksi HIV terlihat sepenuhnya sehat tanpa gejala apapun selama bertahun-tahun.</p>
                </div>

                <!-- Item 3 -->
                <div class="bg-slate-800 p-5 rounded-2xl border border-slate-700 space-y-2">
                    <div class="flex items-center gap-2 text-rose-400 font-bold text-xs uppercase">
                        <i class="fa-solid fa-xmark-circle"></i> Mitos
                    </div>
                    <p class="text-sm font-semibold text-white">"Ibu hamil terinfeksi HIV pasti menurunkan virusnya ke bayinya."</p>
                    <div class="flex items-center gap-2 text-emerald-400 font-bold text-xs uppercase pt-2 border-t border-slate-700/60">
                        <i class="fa-solid fa-check-circle"></i> Fakta
                    </div>
                    <p class="text-xs text-slate-300">Dengan terapi ARV rutin selama kehamilan dan prosedur medis yang tepat, risiko penularan ke bayi dapat ditekan hingga di bawah 1%.</p>
                </div>
            </div>
        </section>

        <!-- SECTION 5: KUIS INTERAKTIF -->
        <section id="quiz-section" class="hidden space-y-6 animate-fade-in">
            <div class="flex items-center justify-between border-b border-slate-700 pb-4">
                <h2 class="text-xl font-bold text-white flex items-center gap-2">
                    <i class="fa-solid fa-graduation-cap text-emerald-400"></i> Kuis Evaluasi Pemahaman
                </h2>
                <button onclick="showSection('home')" class="text-xs bg-slate-800 hover:bg-slate-700 text-slate-300 px-3 py-1.5 rounded-lg border border-slate-700">
                    <i class="fa-solid fa-arrow-left mr-1"></i> Kembali
                </button>
            </div>

            <div class="bg-slate-800 p-6 sm:p-8 rounded-2xl border border-slate-700 space-y-6">
                <div class="flex justify-between items-center text-xs text-slate-400 border-b border-slate-700 pb-3">
                    <span id="quiz-progress">Pertanyaan 1 dari 3</span>
                    <span id="quiz-score-live">Skor: 0</span>
                </div>

                <div id="quiz-container">
                    <h3 id="quiz-question" class="text-base sm:text-lg font-bold text-white mb-4">...</h3>
                    <div id="quiz-options" class="space-y-3">
                        <!-- Pilihan jawaban diisi oleh JavaScript -->
                    </div>
                </div>
            </div>
        </section>

        <!-- SECTION 6: HASIL KUIS -->
        <section id="result-section" class="hidden max-w-md mx-auto my-8 animate-fade-in text-center">
            <div class="bg-slate-800 p-8 rounded-2xl border border-slate-700 space-y-4 card-glow">
                <div class="w-16 h-16 rounded-full bg-emerald-500/20 text-emerald-400 flex items-center justify-center mx-auto text-3xl">
                    <i class="fa-solid fa-award"></i>
                </div>
                <h3 class="text-2xl font-bold text-white">Kuis Selesai!</h3>
                <p class="text-xs text-slate-400">Hasil evaluasi pemahaman kamu:</p>
                
                <div class="text-4xl font-extrabold text-cyan-400 my-2" id="final-score">0 / 100</div>
                <p id="final-message" class="text-xs text-slate-300 italic"></p>

                <div class="pt-4 flex gap-3">
                    <button onclick="startQuiz()" class="flex-1 bg-slate-700 hover:bg-slate-600 text-white font-semibold py-2 rounded-xl text-xs transition">
                        Coba Lagi
                    </button>
                    <button onclick="showSection('home')" class="flex-1 bg-cyan-500 hover:bg-cyan-400 text-slate-950 font-bold py-2 rounded-xl text-xs transition">
                        Menu Utama
                    </button>
                </div>
            </div>
        </section>

        <!-- SECTION 7: LAYANAN VCT -->
        <section id="vct-section" class="hidden space-y-6 animate-fade-in">
            <div class="flex items-center justify-between border-b border-slate-700 pb-4">
                <h2 class="text-xl font-bold text-white flex items-center gap-2">
                    <i class="fa-solid fa-hospital-user text-rose-400"></i> Layanan Tes VCT & Konseling
                </h2>
                <button onclick="showSection('home')" class="text-xs bg-slate-800 hover:bg-slate-700 text-slate-300 px-3 py-1.5 rounded-lg border border-slate-700">
                    <i class="fa-solid fa-arrow-left mr-1"></i> Kembali
                </button>
            </div>

            <div class="bg-slate-800 p-6 rounded-2xl border border-slate-700 space-y-4">
                <h3 class="font-bold text-white text-sm">Apa itu Tes VCT?</h3>
                <p class="text-xs text-slate-300 leading-relaxed">
                    <strong class="text-white">VCT (Voluntary Counseling and Testing)</strong> adalah layanan konseling dan tes HIV secara sukarela. Prosesnya dilakukan secara rahasia (kerahasiaan terjamin) bersama konselor profesional sebelum dan sesudah tes darah.
                </p>

                <div class="pt-4 border-t border-slate-700 space-y-3">
                    <h4 class="font-semibold text-xs text-slate-400 uppercase">Fasilitas Kesehatan Penyedia VCT</h4>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                        <div class="bg-slate-900/60 p-4 rounded-xl border border-slate-700">
                            <h5 class="font-bold text-white text-sm mb-1">Puskesmas Terdekat</h5>
                            <p class="text-xs text-slate-400">Sebagian besar Puskesmas telah menyediakan layanan tes VCT secara gratis atau terjangkau.</p>
                        </div>
                        <div class="bg-slate-900/60 p-4 rounded-xl border border-slate-700">
                            <h5 class="font-bold text-white text-sm mb-1">RSUD & Rumah Sakit Umum</h5>
                            <p class="text-xs text-slate-400">Menyediakan poli khusus konsultasi, pemeriksaan VCT, hingga terapi pendampingan ARV.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- SECTION 8: SIMULASI RISIKO -->
        <section id="simulasi-section" class="hidden space-y-6 animate-fade-in">
            <div class="flex items-center justify-between border-b border-slate-700 pb-4">
                <h2 class="text-xl font-bold text-white flex items-center gap-2">
                    <i class="fa-solid fa-calculator text-amber-400"></i> Simulasi Cek Risiko
                </h2>
                <button onclick="showSection('home')" class="text-xs bg-slate-800 hover:bg-slate-700 text-slate-300 px-3 py-1.5 rounded-lg border border-slate-700">
                    <i class="fa-solid fa-arrow-left mr-1"></i> Kembali
                </button>
            </div>

            <div class="bg-slate-800 p-6 rounded-2xl border border-slate-700 space-y-4 max-w-lg mx-auto">
                <p class="text-xs text-slate-300">Pilih aktivitas di bawah ini untuk mengecek tingkat risikonya terhadap penularan HIV:</p>

                <select id="simulasi-select" onchange="cekSimulasi()" class="w-full bg-slate-900 border border-slate-700 rounded-xl px-4 py-2.5 text-xs text-white focus:outline-none focus:border-cyan-500">
                    <option value="">-- Pilih Aktivitas --</option>
                    <option value="aman1">Makan bersama atau berjabat tangan</option>
                    <option value="aman2">Menggunakan toilet umum yang sama</option>
                    <option value="risiko1">Menggunakan jarum suntik bekas / bergantian</option>
                    <option value="risiko2">Hubungan seksual berisiko tanpa pengaman</option>
                </select>

                <div id="simulasi-result" class="hidden p-4 rounded-xl border text-xs leading-relaxed"></div>
            </div>
        </section>

    </main>

    <!-- FOOTER -->
    <footer class="bg-slate-800/50 border-t border-slate-800 py-6 text-center text-xs text-slate-500">
        <p>&copy; 2026 EduHIV Platform. Dibuat untuk tujuan edukasi kesehatan masyarakat.</p>
    </footer>

    <!-- JAVASCRIPT LOGIC -->
    <script>
        // State Management
        let isRegisterMode = false;
        let currentUser = null;
        let currentQuestionIndex = 0;
        let score = 0;

        // Data Kuis
        const quizData = [
            {
                question: "Bagaimanakah penularan HIV yang utama terjadi di masyarakat?",
                options: [
                    "Melalui gigitan nyamuk",
                    "Hubungan seksual berisiko tanpa pelindung",
                    "Menggunakan toilet yang sama",
                    "Berjabat tangan dengan ODHIV"
                ],
                answer: 1
            },
            {
                question: "Apa singkatan dari istilah obat ARV untuk penanganan HIV?",
                options: [
                    "Anti Respiratory Virus",
                    "Antiretroviral",
                    "Antibiotic Resistance Vaccine",
                    "Active Recovery Virus"
                ],
                answer: 1
            },
            {
                question: "Apakah HIV dapat menular melalui kolam renang umum?",
                options: [
                    "Ya, jika airnya dingin",
                    "Ya, jika berenang bersama ODHIV",
                    "Tidak menular sama sekali",
                    "Hanya menular jika air tidak bersih"
                ],
                answer: 2
            }
        ];

        // Navigasi Section
        window.showSection = function(sectionId) {
            document.getElementById('auth-section').classList.add('hidden');
            document.getElementById('home-section').classList.add('hidden');
            document.getElementById('belajar-section').classList.add('hidden');
            document.getElementById('fakta-section').classList.add('hidden');
            document.getElementById('quiz-section').classList.add('hidden');
            document.getElementById('result-section').classList.add('hidden');
            document.getElementById('vct-section').classList.add('hidden');
            document.getElementById('simulasi-section').classList.add('hidden');

            document.getElementById(`${sectionId}-section`).classList.remove('hidden');
            
            if(sectionId === 'quiz') {
                startQuiz();
            }

            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // Toggle Login / Register
        window.toggleAuthMode = function() {
            isRegisterMode = !isRegisterMode;
            document.getElementById('auth-title').textContent = isRegisterMode ? 'Buat Akun Baru' : 'Selamat Datang';
            document.getElementById('auth-subtitle').textContent = isRegisterMode ? 'Daftar untuk mengakses platform edukasi' : 'Masuk untuk mengakses materi edukasi interaktif';
            document.getElementById('auth-btn').textContent = isRegisterMode ? 'Daftar Sekarang' : 'Masuk Sekarang';
            document.getElementById('auth-toggle-text').textContent = isRegisterMode ? 'Sudah punya akun?' : 'Belum punya akun?';
            document.getElementById('auth-toggle-btn').textContent = isRegisterMode ? 'Masuk' : 'Daftar';
        }

        // Handle Login / Register
        window.handleAuth = function(e) {
            e.preventDefault();
            const name = document.getElementById('auth-name').value;
            currentUser = name;
            
            document.getElementById('user-display-name').textContent = `Halo, ${name}`;
            document.getElementById('nav-user-info').classList.remove('hidden');
            document.getElementById('nav-user-info').classList.add('flex');
            
            showSection('home');
        }

        // Logout
        window.logout = function() {
            currentUser = null;
            document.getElementById('nav-user-info').classList.add('hidden');
            document.getElementById('nav-user-info').classList.remove('flex');
            document.getElementById('auth-form').reset();
            showSection('auth');
        }

        // Kuis Logic
        function startQuiz() {
            currentQuestionIndex = 0;
            score = 0;
            loadQuestion();
        }

        function loadQuestion() {
            const data = quizData[currentQuestionIndex];
            document.getElementById('quiz-progress').textContent = `Pertanyaan ${currentQuestionIndex + 1} dari ${quizData.length}`;
            document.getElementById('quiz-score-live').textContent = `Skor: ${score}`;
            document.getElementById('quiz-question').textContent = data.question;

            const optionsContainer = document.getElementById('quiz-options');
            optionsContainer.innerHTML = '';

            data.options.forEach((option, idx) => {
                const btn = document.createElement('button');
                btn.className = 'w-full text-left bg-slate-900 hover:bg-slate-700/80 p-3.5 rounded-xl border border-slate-700/80 text-xs text-slate-200 transition flex items-center justify-between';
                btn.innerHTML = `<span>${option}</span> <i class="fa-regular fa-circle text-slate-500"></i>`;
                btn.onclick = () => answerQuiz(idx);
                optionsContainer.appendChild(btn);
            });
        }

        function answerQuiz(selectedIndex) {
            if(selectedIndex === quizData[currentQuestionIndex].answer) {
                score += Math.round(100 / quizData.length);
            }

            currentQuestionIndex++;
            if(currentQuestionIndex < quizData.length) {
                loadQuestion();
            } else {
                showQuizResult();
            }
        }

        function showQuizResult() {
            showSection('result');
            document.getElementById('final-score').textContent = `${score} / 100`;
            
            let message = '';
            if(score >= 80) message = "Luar biasa! Kamu memahami informasi kesehatan HIV/AIDS dengan sangat baik.";
            else if(score >= 50) message = "Bagus! Kamu cukup paham, tetapi ada beberapa mitos yang perlu diperbaiki.";
            else message = "Yuk, pelajari kembali materi edukasi untuk lebih memahami fakta HIV/AIDS.";

            document.getElementById('final-message').textContent = message;
        }

        // Simulasi Risiko Logic
        window.cekSimulasi = function() {
            const val = document.getElementById('simulasi-select').value;
            const res = document.getElementById('simulasi-result');
            
            if(!val) {
                res.classList.add('hidden');
                return;
            }

            res.classList.remove('hidden');
            if(val.startsWith('aman')) {
                res.className = "p-4 rounded-xl border text-xs leading-relaxed bg-emerald-500/10 border-emerald-500/30 text-emerald-300";
                res.innerHTML = "<strong><i class='fa-solid fa-shield-check mr-1'></i> TANPA RISIKO:</strong> Aktivitas ini sama sekali tidak menularkan HIV. HIV membutuhkan media cairan tubuh spesifik (seperti darah/cairan kelamin) untuk berpidah.";
            } else {
                res.className = "p-4 rounded-xl border text-xs leading-relaxed bg-rose-500/10 border-rose-500/30 text-rose-300";
                res.innerHTML = "<strong><i class='fa-solid fa-triangle-exclamation mr-1'></i> BERISIKO TINGGI:</strong> Aktivitas ini memiliki potensi penularan virus yang besar. Selalu gunakan pelindung dan hindari penggunaan alat suntik tidak steril.";
            }
        }
    </script>
</body>
</html>
