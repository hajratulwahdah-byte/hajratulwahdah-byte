<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HIV/AIDS Smart Education Awareness</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .card-glow { box-shadow: 0 0 25px rgba(14, 165, 233, 0.15); }
        .anim-float { animation: float 3s ease-in-out infinite; }
        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-8px); }
        }
    </style>
</head>
<body class="bg-slate-950 text-slate-100 min-h-screen flex flex-col">

    <!-- NAVBAR HEADER -->
    <nav class="bg-slate-900/90 backdrop-blur-md sticky top-0 z-50 border-b border-slate-800 px-4 py-3">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <div class="flex items-center gap-2.5 cursor-pointer" onclick="showSection('home')">
                <div class="w-10 h-10 bg-gradient-to-tr from-cyan-600 to-emerald-500 rounded-xl flex items-center justify-center text-white font-bold text-xl shadow-lg shadow-cyan-500/20">
                    <i class="fa-solid fa-shield-virus"></i>
                </div>
                <span class="font-extrabold text-lg bg-gradient-to-r from-cyan-400 via-teal-300 to-emerald-400 bg-clip-text text-transparent">EduYouth HIV</span>
            </div>
            
            <div class="flex items-center gap-3 bg-slate-800/90 px-3.5 py-1.5 rounded-full border border-slate-700/80">
                <div class="flex items-center gap-1.5 text-amber-400">
                    <i class="fa-solid fa-bolt text-sm"></i>
                    <span id="user-xp" class="font-bold text-xs md:text-sm">0 XP</span>
                </div>
                <div class="h-3.5 w-px bg-slate-700"></div>
                <div class="flex items-center gap-1.5 text-cyan-400">
                    <i class="fa-solid fa-award text-sm"></i>
                    <span id="user-badge" class="font-bold text-[11px] md:text-xs">Novice Fighter</span>
                </div>
            </div>
        </div>
    </nav>

    <main class="flex-1 max-w-5xl w-full mx-auto p-4 md:p-6 pb-24">
        
        <!-- SECTION 0: FORM IDENTITAS RESPONDEN -->
        <section id="auth-section" class="hidden space-y-6 animate-fade-in max-w-md mx-auto py-6">
            <div class="bg-slate-900/90 border border-cyan-500/30 p-6 rounded-2xl card-glow space-y-4">
                <div class="text-center space-y-1">
                    <h2 class="text-xl font-bold text-white flex items-center justify-center gap-2">
                        <i class="fa-solid fa-id-card text-cyan-400"></i> Identitas Responden
                    </h2>
                    <p class="text-xs text-slate-400">Isi data diri terlebih dahulu sebelum memulai tes kuesioner ilmiah (20 Soal).</p>
                </div>
                <hr class="border-slate-800">
                <div class="space-y-3">
                    <div>
                        <label class="block text-xs font-semibold text-slate-300 mb-1">Nama Lengkap</label>
                        <input type="text" id="input-nama" placeholder="Masukkan Nama Lengkap" class="w-full bg-slate-950 border border-slate-700 rounded-xl px-3 py-2 text-sm text-white focus:outline-none focus:border-cyan-500">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-300 mb-1">Umur (Tahun)</label>
                        <input type="number" id="input-umur" placeholder="Contoh: 17" class="w-full bg-slate-950 border border-slate-700 rounded-xl px-3 py-2 text-sm text-white focus:outline-none focus:border-cyan-500">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-300 mb-1">Asal Sekolah</label>
                        <input type="text" id="input-sekolah" placeholder="Contoh: SMAN 1 Baubau" class="w-full bg-slate-950 border border-slate-700 rounded-xl px-3 py-2 text-sm text-white focus:outline-none focus:border-cyan-500">
                    </div>
                    <div class="pt-1">
                        <label class="flex items-start gap-2.5 cursor-pointer">
                            <input type="checkbox" id="input-persetujuan" class="mt-0.5 rounded border-slate-700 bg-slate-950 text-cyan-600 focus:ring-0">
                            <span class="text-[11px] text-slate-400 leading-tight">Saya bersedia data pengisian kuesioner ini digunakan untuk analisis instrumen ilmiah secara konsisten & anonim.</span>
                        </label>
                    </div>
                </div>
                <button onclick="submitIdentitas()" class="w-full bg-gradient-to-r from-cyan-600 to-teal-600 hover:from-cyan-500 hover:to-teal-500 text-white font-bold py-2.5 rounded-xl text-sm transition shadow-lg shadow-cyan-600/20">
                    Simpan & Mulai Pre-Test <i class="fa-solid fa-arrow-right ml-1"></i>
                </button>
            </div>
        </section>

        <!-- SECTION 1: HOME -->
        <section id="home-section" class="space-y-8 animate-fade-in">
            <div class="text-center space-y-4 py-6">
                <span class="px-4 py-1.5 rounded-full bg-cyan-500/10 text-cyan-400 text-xs font-semibold uppercase tracking-wider border border-cyan-500/20">Media Edukasi Interaktif & Advanced Test</span>
                <h1 class="text-3xl md:text-5xl font-extrabold text-white tracking-tight">Putus Stigma, <br class="md:hidden"><span class="bg-gradient-to-r from-cyan-400 via-teal-300 to-emerald-400 bg-clip-text text-transparent">Sambung Wawasan Seputar HIV/AIDS</span></h1>
                <p class="text-slate-400 max-w-xl mx-auto text-xs md:text-sm leading-relaxed">Platform pembelajaran berbasis gimik kognitif untuk mengukur serta meningkatkan pengetahuan kesehatan reproduksi secara komprehensif.</p>
            </div>

            <!-- MITOS HARI INI -->
            <div class="bg-slate-900/90 border border-amber-500/30 p-5 rounded-2xl card-glow relative overflow-hidden">
                <div class="absolute top-0 right-0 p-3 opacity-10 text-6xl text-amber-400"><i class="fa-solid fa-dice"></i></div>
                <div class="flex items-center gap-2 text-amber-400 font-bold text-sm mb-2">
                    <i class="fa-solid fa-bolt"></i> <span>Mitos Hari Ini (Asah Otak Instan)</span>
                </div>
                <div id="mitos-hari-ini-body" class="space-y-3">
                    <p id="mhi-question" class="text-sm font-semibold text-white italic">"Loading mitos unik..."</p>
                    <button onclick="revealMitosHariIni()" id="btn-reveal-mhi" class="bg-amber-500 hover:bg-amber-400 text-slate-950 font-bold text-xs px-3 py-1.5 rounded-lg transition">
                        <i class="fa-solid fa-eye mr-1"></i> Cek Faktanya
                    </button>
                    <p id="mhi-explanation" class="hidden text-xs text-slate-300 bg-slate-950/80 p-3 rounded-xl border border-slate-800 leading-relaxed"></p>
                </div>
            </div>

            <!-- LKTI TRACKER -->
            <div class="bg-gradient-to-r from-slate-900 to-slate-800/90 p-6 rounded-2xl border border-cyan-500/30 card-glow flex flex-col md:flex-row justify-between items-center gap-4">
                <div class="space-y-1 text-center md:text-left">
                    <h3 class="font-bold text-lg text-white flex items-center gap-2 justify-center md:justify-start">
                        <i class="fa-solid fa-chart-line text-cyan-400"></i> Tolok Ukur Pengetahuan (Evaluasi 20 Soal)
                    </h3>
                    <p class="text-xs text-slate-400">Uji tingkat pengetahuan medis sebelum (Pre-Test) dan sesudah (Post-Test) membaca materi.</p>
                </div>
                <div class="flex gap-3 w-full md:w-auto">
                    <button onclick="bukaFormIdentitasOrStart()" id="btn-pretest" class="flex-1 md:flex-initial bg-cyan-600 hover:bg-cyan-500 text-white px-5 py-2.5 rounded-xl font-bold text-sm transition shadow-lg shadow-cyan-600/20 whitespace-nowrap"><i class="fa-solid fa-play mr-2"></i>Mulai Pre-Test</button>
                    <button onclick="startTest('post')" id="btn-posttest" class="flex-1 md:flex-initial bg-slate-800 opacity-50 cursor-not-allowed text-white px-5 py-2.5 rounded-xl font-bold text-sm transition whitespace-nowrap" disabled><i class="fa-solid fa-graduation-cap mr-2"></i>Mulai Post-Test</button>
                </div>
            </div>

            <!-- SKOR BOX -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="bg-slate-900/80 p-5 rounded-2xl border border-slate-800 flex items-center gap-4">
                    <div class="w-12 h-12 rounded-xl bg-cyan-500/10 flex items-center justify-center text-cyan-400 text-xl"><i class="fa-solid fa-bullseye"></i></div>
                    <div>
                        <div class="text-xs text-slate-400">Skor Pre-Test (20 Soal)</div>
                        <div id="dash-pre" class="text-xl font-bold text-white">-</div>
                    </div>
                </div>
                <div class="bg-slate-900/80 p-5 rounded-2xl border border-slate-800 flex items-center gap-4">
                    <div class="w-12 h-12 rounded-xl bg-teal-500/10 flex items-center justify-center text-teal-400 text-xl"><i class="fa-solid fa-trophy"></i></div>
                    <div>
                        <div class="text-xs text-slate-400">Skor Post-Test (20 Soal)</div>
                        <div id="dash-post" class="text-xl font-bold text-white">-</div>
                    </div>
                </div>
                <div class="bg-slate-900/80 p-5 rounded-2xl border border-slate-800 flex items-center gap-4">
                    <div class="w-12 h-12 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-400 text-xl"><i class="fa-solid fa-arrow-trend-up"></i></div>
                    <div>
                        <div class="text-xs text-slate-400">Efektivitas Belajar</div>
                        <div id="dash-gain" class="text-xl font-bold text-emerald-400">-</div>
                    </div>
                </div>
            </div>

            <!-- MENU UTAMA CARD -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 pt-2">
                <button onclick="showSection('belajar')" class="p-5 text-left bg-slate-900 hover:bg-slate-800/80 rounded-2xl border border-slate-800 transition duration-300 group">
                    <div class="w-12 h-12 rounded-xl bg-cyan-500/10 flex items-center justify-center text-cyan-400 text-xl mb-4 group-hover:scale-110 transition"><i class="fa-solid fa-book-open"></i></div>
                    <h4 class="font-bold text-white mb-1">Menu Belajar</h4>
                    <p class="text-xs text-slate-400">Pelajari materi HIV, imunologi CD4, transmisi, serta profilaksis PrEP/PEP.</p>
                </button>
                <button onclick="startFaktaMitos()" class="p-5 text-left bg-slate-900 hover:bg-slate-800/80 rounded-2xl border border-slate-800 transition duration-300 group">
                    <div class="w-12 h-12 rounded-xl bg-amber-500/10 flex items-center justify-center text-amber-400 text-xl mb-4 group-hover:scale-110 transition"><i class="fa-solid fa-circle-question"></i></div>
                    <h4 class="font-bold text-white mb-1">Fakta vs Mitos Advanced</h4>
                    <p class="text-xs text-slate-400">Uji 10 mitos medis & epidemiologi tingkat tinggi yang kerap dipahami salah.</p>
                </button>
                <button onclick="startQuiz()" class="p-5 text-left bg-slate-900 hover:bg-slate-800/80 rounded-2xl border border-slate-800 transition duration-300 group">
                    <div class="w-12 h-12 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-400 text-xl mb-4 group-hover:scale-110 transition"><i class="fa-solid fa-gamepad"></i></div>
                    <h4 class="font-bold text-white mb-1">Kuis Latihan Mandiri</h4>
                    <p class="text-xs text-slate-400">Tantang wawasan dengan 20 soal kognitif ber-skor presisi & klaim XP-mu.</p>
                </button>
                <button onclick="showSection('simulasi')" class="p-5 text-left bg-slate-900 hover:bg-slate-800/80 rounded-2xl border border-slate-800 transition duration-300 group">
                    <div class="w-12 h-12 rounded-xl bg-violet-500/10 flex items-center justify-center text-violet-400 text-xl mb-4 group-hover:scale-110 transition"><i class="fa-solid fa-virus-covid"></i></div>
                    <h4 class="font-bold text-white mb-1">Simulasi Risiko</h4>
                    <p class="text-xs text-slate-400">Pilih tindakan klinis/sosial untuk menguji analisis potensi tingkat paparan.</p>
                </button>
                <button onclick="showSection('vct')" class="p-5 text-left bg-slate-900 hover:bg-slate-800/80 rounded-2xl border border-slate-800 transition duration-300 group">
                    <div class="w-12 h-12 rounded-xl bg-teal-500/10 flex items-center justify-center text-teal-400 text-xl mb-4 group-hover:scale-110 transition"><i class="fa-solid fa-map-location-dot"></i></div>
                    <h4 class="font-bold text-white mb-1">Layanan Kesehatan VCT</h4>
                    <p class="text-xs text-slate-400">Informasi standar alur konsultasi rahasia & tes klinis HIV sukarela.</p>
                </button>
            </div>
        </section>

        <!-- SECTION 2: MENU BELAJAR -->
        <section id="belajar-section" class="hidden space-y-6 animate-fade-in">
            <div class="flex flex-wrap gap-2 p-1.5 bg-slate-900/80 rounded-xl border border-slate-800 overflow-x-auto">
                <button onclick="switchTab('pengertian')" class="tab-btn active-tab flex-1 min-w-[120px] px-4 py-2 rounded-lg font-bold text-xs md:text-sm text-center transition bg-cyan-600 text-white">Pengertian</button>
                <button onclick="switchTab('imun')" class="tab-btn flex-1 min-w-[120px] px-4 py-2 rounded-lg font-bold text-xs md:text-sm text-center text-slate-400 transition">Sistem Imun</button>
                <button onclick="switchTab('penularan')" class="tab-btn flex-1 min-w-[120px] px-4 py-2 rounded-lg font-bold text-xs md:text-sm text-center text-slate-400 transition">Cara Penularan</button>
                <button onclick="switchTab('pencegahan')" class="tab-btn flex-1 min-w-[120px] px-4 py-2 rounded-lg font-bold text-xs md:text-sm text-center text-slate-400 transition">Pencegahan</button>
            </div>

            <div id="tab-pengertian" class="tab-content bg-slate-900/60 p-6 rounded-2xl border border-slate-800 space-y-4">
                <div class="flex items-center gap-3 border-b border-slate-800 pb-3">
                    <i class="fa-solid fa-dna text-cyan-400 text-2xl"></i>
                    <h2 class="text-xl font-bold text-white">Apa beda HIV dan AIDS?</h2>
                </div>
                <p class="text-sm md:text-base leading-relaxed text-slate-300">
                    Secara terminologi biologis, **HIV** dan **AIDS** merepresentasikan tahap diagnosis yang berbeda.
                </p>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 pt-2">
                    <div class="p-4 bg-slate-900 rounded-xl border-l-4 border-cyan-500">
                        <span class="font-bold text-cyan-400 text-sm block mb-1">HIV (Human Immunodeficiency Virus)</span>
                        <p class="text-xs text-slate-300 leading-relaxed">Adalah **retro-virus** yang secara spesifik menyerang sistem pertahanan tubuh manusia. Seseorang yang terinfeksi disebut ODHIV (Orang Dengan HIV) dan bisa tampak bugar tanpa gejala khas selama bertahun-tahun.</p>
                    </div>
                    <div class="p-4 bg-slate-900 rounded-xl border-l-4 border-rose-500">
                        <span class="font-bold text-rose-400 text-sm block mb-1">AIDS (Acquired Immunodeficiency Syndrome)</span>
                        <p class="text-xs text-slate-300 leading-relaxed">Adalah **stadium akhir/kumpulan gejala** manifestasi rusaknya kekebalan tubuh akibat infeksi HIV yang tidak ditangani dengan obat ARV. Pada tahap ini, infeksi oportunistik mudah masuk.</p>
                    </div>
                </div>
            </div>

            <div id="tab-imun" class="tab-content hidden bg-slate-900/60 p-6 rounded-2xl border border-slate-800 space-y-4">
                <div class="flex items-center gap-3 border-b border-slate-800 pb-3">
                    <i class="fa-solid fa-shield-halved text-emerald-400 text-2xl"></i>
                    <h2 class="text-xl font-bold text-white">Mekanisme Patogenesis: HIV vs Sel T CD4+</h2>
                </div>
                <p class="text-sm md:text-base leading-relaxed text-slate-300">
                    Limfosit **Sel T Helper (CD4+)** berfungsi sebagai pengatur respon imun tubuh manusia terhadap mikroorganisme asing.
                </p>
                <div class="bg-slate-900 p-4 rounded-xl flex items-start gap-3 border border-slate-800">
                    <div class="text-amber-400 text-lg mt-0.5"><i class="fa-solid fa-triangle-exclamation"></i></div>
                    <p class="text-xs text-slate-300 leading-relaxed">
                        **Bagaimana HIV Merusak Tubuh?** Virus menempel pada reseptor CD4 dan koreseptor (CCR5/CXCR4) sel inang, menyuntikkan RNA-nya, menggunakan enzim *reverse transcriptase* untuk mengubah RNA menjadi DNA, lalu mengintegrasikannya ke genom sel manusia. Sel CD4 dibajak untuk memproduksi partikel virus baru, yang berujung pada lisis (kematian) sel CD4 secara masif.
                    </p>
                </div>
            </div>

            <div id="tab-penularan" class="tab-content hidden bg-slate-900/60 p-6 rounded-2xl border border-slate-800 space-y-4">
                <div class="flex items-center gap-3 border-b border-slate-800 pb-3">
                    <i class="fa-solid fa-right-left text-pink-400 text-2xl"></i>
                    <h2 class="text-xl font-bold text-white">Prinsip Transmisi (4 Cairan Spesifik)</h2>
                </div>
                <p class="text-sm text-slate-300">Penularan HIV mensyaratkan adanya volume & konsentrasi virus yang mencukupi melalui 4 cairan tubuh utama:</p>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                    <div class="p-3 bg-slate-900 rounded-xl text-center font-semibold text-xs border border-slate-800 text-rose-400">Darah Segar</div>
                    <div class="p-3 bg-slate-900 rounded-xl text-center font-semibold text-xs border border-slate-800 text-cyan-400">Cairan Semen/Sperma</div>
                    <div class="p-3 bg-slate-900 rounded-xl text-center font-semibold text-xs border border-slate-800 text-purple-400">Cairan Vagina</div>
                    <div class="p-3 bg-slate-900 rounded-xl text-center font-semibold text-xs border border-slate-800 text-amber-400">Air Susu Ibu (ASI)</div>
                </div>
                <p class="text-xs text-slate-400 bg-slate-900 p-3 rounded-xl border border-slate-800">⚠️ **Integritas Kulit:** Penularan hanya terjadi jika cairan berisiko tersebut kontak langsung dengan aliran darah terbuka atau mukosa yang luka/membran mukosa aktif.</p>
            </div>

            <div id="tab-pencegahan" class="tab-content hidden bg-slate-900/60 p-6 rounded-2xl border border-slate-800 space-y-4">
                <div class="flex items-center gap-3 border-b border-slate-800 pb-3">
                    <i class="fa-solid fa-stethoscope text-teal-400 text-2xl"></i>
                    <h2 class="text-xl font-bold text-white">Strategi Pencegahan Komprehensif (ABCDE & Profilaksis)</h2>
                </div>
                <div class="space-y-3">
                    <div class="bg-slate-900 p-3.5 rounded-xl text-xs border border-slate-800"><b class="text-cyan-400">A - Abstinence:</b> Tidak melakukan hubungan seksual bagi yang belum menikah.</div>
                    <div class="bg-slate-900 p-3.5 rounded-xl text-xs border border-slate-800"><b class="text-cyan-400">B - Be Faithful:</b> Saling setia pada satu pasangan sah yang tidak terinfeksi.</div>
                    <div class="bg-slate-900 p-3.5 rounded-xl text-xs border border-slate-800"><b class="text-cyan-400">C - Condom:</b> Penggunaan kondom secara konsisten pada penetrasi berisiko.</div>
                    <div class="bg-slate-900 p-3.5 rounded-xl text-xs border border-slate-800"><b class="text-cyan-400">D - Drug No:</b> Menghindari penyalahgunaan NAPZA, terutama jarum suntik steril bergantian.</div>
                    <div class="bg-slate-900 p-3.5 rounded-xl text-xs border border-slate-800"><b class="text-cyan-400">E - Education & PEP/PrEP:</b> Penggunaan profilaksis medis seperti PrEP (sebelum paparan) dan PEP (maksimal 72 jam setelah paparan insidental).</div>
                </div>
            </div>
        </section>

        <!-- SIMULASI RISIKO PENULARAN HIV -->
        <section id="simulasi-section" class="hidden space-y-6 animate-fade-in">
            <div class="bg-slate-900/90 p-6 rounded-2xl border border-slate-800 card-glow space-y-4">
                <div class="flex items-center gap-3 border-b border-slate-800 pb-3">
                    <i class="fa-solid fa-virus-covid text-violet-400 text-2xl"></i>
                    <h2 class="text-xl font-bold text-white">Simulator Analisis Risiko Transmisi Klinik</h2>
                </div>
                <p class="text-xs md:text-sm text-slate-300">Pilih salah satu kondisi aktivitas sosial atau tindakan medis di bawah untuk melihat tingkat potensi transmisinya secara obyektif:</p>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3" id="simulasi-options-box">
                    <button onclick="runSimulasi('peluk')" class="w-full text-left p-4 rounded-xl bg-slate-950 hover:bg-slate-800/50 border border-slate-800 text-xs md:text-sm font-medium flex justify-between items-center text-slate-100 transition">
                        <span><i class="fa-solid fa-people-arrows mr-2 text-cyan-400"></i> Kontak Fisik Sosial (Pelukan/Jabat Tangan)</span>
                        <i class="fa-solid fa-chevron-right text-slate-500"></i>
                    </button>
                    <button onclick="runSimulasi('makan')" class="w-full text-left p-4 rounded-xl bg-slate-950 hover:bg-slate-800/50 border border-slate-800 text-xs md:text-sm font-medium flex justify-between items-center text-slate-100 transition">
                        <span><i class="fa-solid fa-utensils mr-2 text-cyan-400"></i> Menggunakan Alat Makan Berdua</span>
                        <i class="fa-solid fa-chevron-right text-slate-500"></i>
                    </button>
                    <button onclick="runSimulasi('jarum')" class="w-full text-left p-4 rounded-xl bg-slate-950 hover:bg-slate-800/50 border border-slate-800 text-xs md:text-sm font-medium flex justify-between items-center text-slate-100 transition">
                        <span><i class="fa-solid fa-syringe mr-2 text-cyan-400"></i> Pemakaian Jarum Suntik Unsteril Bergantian</span>
                        <i class="fa-solid fa-chevron-right text-slate-500"></i>
                    </button>
                    <button onclick="runSimulasi('transfusi')" class="w-full text-left p-4 rounded-xl bg-slate-950 hover:bg-slate-800/50 border border-slate-800 text-xs md:text-sm font-medium flex justify-between items-center text-slate-100 transition">
                        <span><i class="fa-solid fa-droplet mr-2 text-cyan-400"></i> Transfusi Darah Tanpa Skrining Lab</span>
                        <i class="fa-solid fa-chevron-right text-slate-500"></i>
                    </button>
                    <button onclick="runSimulasi('uu')" class="w-full text-left p-4 rounded-xl bg-slate-950 hover:bg-slate-800/50 border border-slate-800 text-xs md:text-sm font-medium flex justify-between items-center text-slate-100 transition">
                        <span><i class="fa-solid fa-notes-medical mr-2 text-cyan-400"></i> Hubungan Seksual Pasangan ODHIV Viral Load Undetectable (U=U)</span>
                        <i class="fa-solid fa-chevron-right text-slate-500"></i>
                    </button>
                    <button onclick="runSimulasi('seks')" class="w-full text-left p-4 rounded-xl bg-slate-950 hover:bg-slate-800/50 border border-slate-800 text-xs md:text-sm font-medium flex justify-between items-center text-slate-100 transition">
                        <span><i class="fa-solid fa-heart-crack mr-2 text-cyan-400"></i> Hubungan Seksual Penetrasi Tanpa Pengaman</span>
                        <i class="fa-solid fa-chevron-right text-slate-500"></i>
                    </button>
                </div>

                <div id="simulasi-result-card" class="hidden p-5 rounded-2xl border transition duration-300 space-y-2">
                    <div class="flex items-center gap-2 font-bold text-base" id="sim-badge-status"></div>
                    <p id="sim-explanation-text" class="text-xs md:text-sm text-slate-300 leading-relaxed"></p>
                </div>
            </div>
        </section>

        <!-- SECTION 3: FAKTA ATAU MITOS -->
        <section id="fakta-section" class="hidden space-y-6 animate-fade-in">
            <div class="bg-slate-900/90 p-6 rounded-2xl border border-slate-800 card-glow space-y-4">
                <div class="flex justify-between items-center text-xs text-slate-400">
                    <span>Aktivitas: <b class="text-amber-400">Fakta vs Mitos Advanced</b></span>
                    <span id="fakta-progress">Soal 1 dari 10</span>
                </div>
                <div class="w-full bg-slate-800 h-2 rounded-full overflow-hidden">
                    <div id="fakta-bar" class="bg-amber-500 h-full w-[10%] transition-all duration-300"></div>
                </div>

                <div class="py-4 space-y-3 text-center">
                    <div id="fakta-bubble-avatar" class="w-16 h-16 bg-amber-500/10 border border-amber-500/30 rounded-full flex items-center justify-center mx-auto text-2xl text-amber-400 mb-2 anim-float">
                        <i class="fa-solid fa-lightbulb"></i>
                    </div>
                    <p id="fakta-question-text" class="text-base md:text-lg font-bold text-white max-w-2xl mx-auto px-2">"..."</p>
                </div>

                <div class="grid grid-cols-2 gap-4" id="fakta-btn-group">
                    <button id="btn-fakta-true" onclick="checkFakta(true)" class="p-4 rounded-xl bg-emerald-600 hover:bg-emerald-500 text-white font-bold tracking-wide transition shadow-lg shadow-emerald-600/10">FAKTA</button>
                    <button id="btn-fakta-false" onclick="checkFakta(false)" class="p-4 rounded-xl bg-rose-600 hover:bg-rose-500 text-white font-bold tracking-wide transition shadow-lg shadow-rose-600/10">MITOS</button>
                </div>

                <div id="fakta-feedback" class="hidden p-5 rounded-xl space-y-3 border transition duration-300">
                    <div class="flex items-center gap-2 font-bold text-base" id="fakta-status-title"></div>
                    <p id="fakta-explanation" class="text-xs md:text-sm leading-relaxed text-slate-300"></p>
                    <button onclick="nextFakta()" class="bg-slate-800 hover:bg-slate-700 text-white text-xs px-4 py-2 rounded-lg font-bold transition ml-auto block">Lanjutkan <i class="fa-solid fa-arrow-right ml-1"></i></button>
                </div>
            </div>
        </section>

        <!-- SECTION 4: KUIS INTERAKTIF (20 SOAL PRE/POST TEST) -->
        <section id="quiz-section" class="hidden space-y-6 animate-fade-in">
            <div class="bg-slate-900/90 p-6 rounded-2xl border border-slate-800 card-glow space-y-4">
                <div class="flex justify-between items-center text-xs text-slate-400">
                    <span id="quiz-badge-type">Aktivitas: <b class="text-cyan-400">Kuis Evaluasi (20 Nomor)</b></span>
                    <span id="quiz-progress">Soal 1 dari 20</span>
                </div>
                <div class="w-full bg-slate-800 h-2 rounded-full overflow-hidden">
                    <div id="quiz-bar" class="bg-cyan-500 h-full w-[5%] transition-all duration-300"></div>
                </div>

                <div class="py-2">
                    <p id="quiz-question-text" class="text-base md:text-lg font-bold text-white leading-snug">...</p>
                </div>

                <div class="flex flex-col gap-2.5" id="quiz-options-container"></div>

                <div id="quiz-feedback" class="hidden p-5 rounded-xl space-y-3 border transition duration-300">
                    <div class="flex items-center gap-2 font-bold text-base" id="quiz-status-title"></div>
                    <p id="quiz-explanation" class="text-xs md:text-sm leading-relaxed text-slate-300"></p>
                    <button onclick="nextQuiz()" class="bg-slate-800 hover:bg-slate-700 text-white text-xs px-4 py-2 rounded-lg font-bold transition ml-auto block">Soal Berikutnya <i class="fa-solid fa-arrow-right ml-1"></i></button>
                </div>
            </div>
        </section>

        <!-- SECTION 5: REKAPITULASI HASIL -->
        <section id="result-section" class="hidden space-y-6 animate-fade-in text-center py-8">
            <div class="bg-slate-900/90 p-8 rounded-3xl border border-slate-800 max-w-xl mx-auto card-glow space-y-6">
                <div id="result-icon-container" class="w-24 h-24 rounded-full bg-cyan-500/10 flex items-center justify-center mx-auto text-4xl text-cyan-400 anim-float">
                    <i class="fa-solid fa-square-poll-horizontal"></i>
                </div>
                <h2 class="text-3xl font-extrabold text-white" id="result-title">Hasil Evaluasi</h2>
                
                <div class="p-6 bg-slate-950/80 rounded-2xl border border-slate-800 max-w-xs mx-auto">
                    <span class="text-xs text-slate-400 block mb-1 uppercase tracking-wider font-semibold">Skor Akhir (Skala 100)</span>
                    <span class="text-5xl font-black text-transparent bg-gradient-to-r from-cyan-400 via-teal-300 to-emerald-400 bg-clip-text" id="result-score">0 / 100</span>
                </div>

                <p id="result-message" class="text-sm text-slate-300 leading-relaxed px-4 font-medium"></p>
                
                <div class="pt-2">
                    <button onclick="showSection('home')" class="bg-cyan-600 hover:bg-cyan-500 text-white font-bold px-6 py-2.5 rounded-xl text-sm transition shadow-md shadow-cyan-600/20"><i class="fa-solid fa-house mr-2"></i>Kembali ke Beranda</button>
                </div>
            </div>
        </section>

        <!-- SECTION 6: PETA FASKES VCT -->
        <section id="vct-section" class="hidden space-y-6 animate-fade-in">
            <div class="bg-slate-900/60 p-6 rounded-2xl border border-slate-800 space-y-4">
                <div class="flex items-center gap-3 border-b border-slate-800 pb-3">
                    <i class="fa-solid fa-hospital text-teal-400 text-2xl"></i>
                    <h2 class="text-xl font-bold text-white">Prinsip & Layanan Konseling VCT</h2>
                </div>
                <p class="text-xs md:text-sm text-slate-300">Layanan **VCT (Voluntary Counseling and Testing)** adalah proses konseling dan pemeriksaan tes HIV yang bersifat **Sukarela**, **Kerahasiaan Terjamin (Confidential)**, dan didampingi Konselor Profesional di Puskesmas maupun Rumah Sakit Rujukan PDP terdekat.</p>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 pt-2">
                    <div class="p-4 bg-slate-900 rounded-xl border border-slate-800 space-y-1">
                        <span class="font-bold text-sm text-white block">Konseling Pra-Tes</span>
                        <p class="text-xs text-slate-400">Diskusi awal mengenai faktor risiko, prosedur tes, dan kesiapan mental responden.</p>
                        <span class="inline-block mt-2 px-2 py-0.5 rounded text-[10px] font-semibold bg-cyan-500/10 text-cyan-400 border border-cyan-500/20">Tahap 1</span>
                    </div>
                    <div class="p-4 bg-slate-900 rounded-xl border border-slate-800 space-y-1">
                        <span class="font-bold text-sm text-white block">Pemeriksaan Laboratorium</span>
                        <p class="text-xs text-slate-400">Pengambilan sampel darah untuk uji Rapid Test Antibodi/Antigen HIV secara steril.</p>
                        <span class="inline-block mt-2 px-2 py-0.5 rounded text-[10px] font-semibold bg-teal-500/10 text-teal-400 border border-teal-500/20">Tahap 2</span>
                    </div>
                    <div class="p-4 bg-slate-900 rounded-xl border border-slate-800 space-y-1">
                        <span class="font-bold text-sm text-white block">Konseling Pasca-Tes</span>
                        <p class="text-xs text-slate-400">Penyampaian hasil secara tertutup serta pemberian dukungan/rujukan ARV jika reaktif.</p>
                        <span class="inline-block mt-2 px-2 py-0.5 rounded text-[10px] font-semibold bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">Tahap 3</span>
                    </div>
                    <div class="p-4 bg-slate-900 rounded-xl border border-slate-800 space-y-1">
                        <span class="font-bold text-sm text-white block">Pendampingan Pengobatan ARV</span>
                        <p class="text-xs text-slate-400">Layanan PDP (Perawatan, Dukungan, dan Pengobatan) secara berkelanjutan.</p>
                        <span class="inline-block mt-2 px-2 py-0.5 rounded text-[10px] font-semibold bg-indigo-500/10 text-indigo-400 border border-indigo-500/20">Tahap Lanjutan</span>
                    </div>
                </div>
            </div>
        </section>

    </main>

    <!-- FLOATING CHAT OVERLAY (GENERIC & ALL-ROUNDER AI CHATBOT) -->
    <div class="fixed bottom-16 right-4 z-50 flex flex-col items-end gap-2 max-w-[340px] w-full px-2">
        <div id="chat-window" class="hidden bg-slate-900 border border-slate-800 rounded-2xl shadow-2xl overflow-hidden w-full flex flex-col h-[380px] card-glow animate-fade-in">
            <div class="bg-gradient-to-r from-cyan-600 to-teal-600 p-3 flex justify-between items-center text-white">
                <div class="flex items-center gap-2">
                    <i class="fa-solid fa-robot text-sm text-amber-300"></i>
                    <span class="text-xs font-bold tracking-wide">EduYouth AI Assistant</span>
                </div>
                <button onclick="toggleChat()" class="text-white hover:text-slate-200 text-xs"><i class="fa-solid fa-minus"></i></button>
            </div>
            <div id="chat-messages-container" class="flex-1 p-3 overflow-y-auto space-y-2 text-xs">
                <div class="bg-slate-950/85 p-2.5 rounded-xl border border-slate-800 text-slate-300">
                    Halo! Saya AI Assistant pintar. Anda dapat menanyakan **apa saja** — baik seputar HIV/AIDS, sains umum, matematika, maupun topik sains populer lainnya!
                </div>
            </div>
            <div class="p-2 bg-slate-950 border-t border-slate-800 flex gap-1">
                <input type="text" id="chat-input-field" placeholder="Tanyakan apa saja..." onkeypress="handleChatKeyPress(event)" class="flex-1 bg-slate-900 border border-slate-700 rounded-lg px-2.5 py-1 text-xs text-white focus:outline-none focus:border-cyan-500">
                <button onclick="sendChatMessage()" class="bg-cyan-600 hover:bg-cyan-500 text-white rounded-lg px-3 py-1 text-xs transition"><i class="fa-solid fa-paper-plane"></i></button>
            </div>
        </div>
        <button onclick="toggleChat()" class="w-12 h-12 bg-cyan-600 hover:bg-cyan-500 text-white rounded-full flex items-center justify-center shadow-lg shadow-cyan-600/30 transition hover:scale-105 border border-cyan-400/20">
            <i class="fa-solid fa-comments text-lg"></i>
        </button>
    </div>

    <!-- BOTTOM NAVBAR MOBILE -->
    <footer class="bg-slate-900/90 backdrop-blur-lg border-t border-slate-800 fixed bottom-0 left-0 right-0 py-2.5 z-40">
        <div class="max-w-xl mx-auto flex justify-around items-center px-4">
            <button onclick="showSection('home')" class="flex flex-col items-center gap-1 text-slate-400 hover:text-white transition">
                <i class="fa-solid fa-house text-lg"></i><span class="text-[10px] font-medium">Beranda</span>
            </button>
            <button onclick="showSection('belajar')" class="flex flex-col items-center gap-1 text-slate-400 hover:text-white transition">
                <i class="fa-solid fa-book-open text-lg"></i><span class="text-[10px] font-medium">Belajar</span>
            </button>
            <button onclick="startFaktaMitos()" class="flex flex-col items-center gap-1 text-slate-400 hover:text-white transition">
                <i class="fa-solid fa-circle-question text-lg"></i><span class="text-[10px] font-medium">Fakta/Mitos</span>
            </button>
            <button onclick="startQuiz()" class="flex flex-col items-center gap-1 text-slate-400 hover:text-white transition">
                <i class="fa-solid fa-gamepad text-lg"></i><span class="text-[10px] font-medium">Kuis</span>
            </button>
            <button onclick="showSection('vct')" class="flex flex-col items-center gap-1 text-slate-400 hover:text-white transition">
                <i class="fa-solid fa-map-location-dot text-lg"></i><span class="text-[10px] font-medium">VCT</span>
            </button>
        </div>
    </footer>

    <!-- FIREBASE & CORE ENGINE -->
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
        import { getFirestore, collection, addDoc } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";

        const firebaseConfig = {
            apiKey: "AIzaSyCZw8NZkgoGF_IQMGZSumIwVdtMR_s7r_8",
            authDomain: "hiv-smart-education.firebaseapp.com",
            projectId: "hiv-smart-education",
            storageBucket: "hiv-smart-education.firebasestorage.app",
            messagingSenderId: "177485557153",
            appId: "1:177485557153:web:d4d76c0877a150b347afe0",
            measurementId: "G-33TZL2CVEF"
        };

        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);

        let dataResponden = {
            nama: "",
            umur: "",
            sekolah: "",
            skorPretest: null,
            skorPosttest: null
        };

        window.bukaFormIdentitasOrStart = function() {
            if (!dataResponden.nama) {
                showSection('auth');
            } else {
                startTest('pre');
            }
        }

        window.submitIdentitas = function() {
            const nama = document.getElementById('input-nama').value.trim();
            const umur = document.getElementById('input-umur').value.trim();
            const sekolah = document.getElementById('input-sekolah').value.trim();
            const persetujuan = document.getElementById('input-persetujuan').checked;

            if (!nama || !umur || !sekolah) {
                alert("Mohon isi seluruh data identitas Anda terlebih dahulu!");
                return;
            }
            if (!persetujuan) {
                alert("Anda harus mencentang persetujuan penggunaan data kuesioner.");
                return;
            }

            dataResponden.nama = nama;
            dataResponden.umur = parseInt(umur);
            dataResponden.sekolah = sekolah;

            startTest('pre');
        }

        async function kirimDataKeFirebase(finalScorePre, finalScorePost) {
            try {
                const gain = finalScorePost - finalScorePre;
                await addDoc(collection(db, "peserta"), {
                    nama: dataResponden.nama,
                    umur: dataResponden.umur,
                    sekolah: dataResponden.sekolah,
                    pretest: finalScorePre,
                    posttest: finalScorePost,
                    efektivitas_gain: gain,
                    tanggal: new Date()
                });
                console.log("Data kuesioner berhasil terkirim ke Firestore Cloud.");
            } catch (error) {
                console.error("Gagal mengirim data ke Firebase: ", error);
            }
        }

        // ==========================================
        // SOAL FAKTA VS MITOS (10 NOMOR LEBIH SULIT)
        // ==========================================
        const faktaMitosData = [
            { 
                q: "Pasien ODHIV dengan status Viral Load Undetectable (tak terdeteksi) selama minimal 6 bulan berturut-turut masih dapat menularkan HIV secara seksual ke pasangannya.", 
                isFakta: false, 
                exp: "**Jawabannya: MITOS.** Berdasarkan konsensus ilmiah global **U=U (Undetectable = Untransmittable)**, kadar virus yang tidak terdeteksi pada tes darah menjadikan risiko penularan seksual secara matematis adalah NOL." 
            },
            { 
                q: "Virus HIV tipe 1 (HIV-1) dan HIV tipe 2 (HIV-2) memiliki tingkat virulensi serta laju perkembangan penyakit yang berbeda pada sistem imun manusia.", 
                isFakta: true, 
                exp: "**Jawabannya: FAKTA.** HIV-1 jauh lebih virulen dan dominan secara global, sedangkan HIV-2 memiliki laju replikasi lebih lambat serta masa laten yang lebih panjang." 
            },
            { 
                q: "Penggunaan obat Post-Exposure Prophylaxis (PEP) masih efektif mencegah infeksi walaupun baru pertama kali diminum pada hari ke-5 (120 jam) setelah kejadian paparan berisiko.", 
                isFakta: false, 
                exp: "**Jawabannya: MITOS.** Rejimen PEP wajib diinisiasi **maksimal 72 jam** (3 hari) setelah insiden paparan insidental. Lewat dari 72 jam, efektivitas pencegahannya menurun drastis." 
            },
            { 
                q: "Air mata, ludah, dan keringat ODHIV secara klinis tidak mengandung konsentrasi partikel virus HIV yang cukup untuk mentransmisikan infeksi.", 
                isFakta: true, 
                exp: "**Jawabannya: FAKTA.** Cairan tubuh non-esensial tersebut mengandung viral load yang sangat amat rendah sehingga secara epidemiologi tidak sanggup menginfeksi sel inang baru." 
            },
            { 
                q: "Terapi Antiretroviral (ARV) berfungsi memusnahkan total keberadaan reservoir virus HIV terintegrasi dari dalam genom sel CD4 manusia.", 
                isFakta: false, 
                exp: "**Jawabannya: MITOS.** ARV bekerja menekan proses *reverse transcription* dan perakitan virus baru (replikasi), namun belum mampu menghapus *latent proviral DNA* di dalam reservoir sel inang." 
            },
            { 
                q: "Ibu hamil positif HIV yang rutin mengonsumsi ARV dan menjalani prosedur persalinan terpimpin dapat menurunkan risiko penularan ke bayinya hingga di bawah 1%.", 
                isFakta: true, 
                exp: "**Jawabannya: FAKTA.** Intervensi PMTCT (Prevention of Mother-to-Child Transmission) terintegrasi menekan transmisi vertikal dari angka 30-45% menjadi kurang dari 1%." 
            },
            { 
                q: "Hasil tes Rapid Diagnostic Test (RDT) Antibodi HIV yang positif pada hari ke-2 setelah paparan berisiko tinggi membuktikan pasien langsung tertular saat insiden tersebut.", 
                isFakta: false, 
                exp: "**Jawabannya: MITOS.** Pembentukan antibodi tubuh memerlukan 'Window Period' (2 minggu-3 bulan). Tes positif pada hari ke-2 menunjukkan infeksi lama yang telah terjadi minggu/bulan sebelumnya." 
            },
            { 
                q: "Nyamuk dapat menularkan HIV karena menyimpan darah sisa mangsa di dalam saluran liurnya saat menggigit manusia berikutnya.", 
                isFakta: false, 
                exp: "**Jawabannya: MITOS.** Nyamuk mencerna darah dan tidak memiliki reseptor spesifik bagi HIV untuk hidup di saluran kelenjar ludahnya; mekanisme gigitannya adalah injeksi ludah, bukan darah sisa." 
            },
            { 
                q: "Infeksi Oportunistik (seperti TBC Paru berat atau Kriptokokus) merupakan penyebab utama mortalitas pada penderita stadium AIDS.", 
                isFakta: true, 
                exp: "**Jawabannya: FAKTA.** Kematian pada kondisi AIDS umumnya tidak disebabkan langsung oleh virus HIV itu sendiri, melainkan oleh patogen oportunistik yang menyerang saat limfosit CD4 jatuh di bawah 200 sel/µL." 
            },
            { 
                q: "Mutasi genetik alami pada koreseptor CCR5 (seperti CCR5-delta 32) dapat memberikan resistensi alami pada sebagian kecil individu terhadap strain HIV tertentu.", 
                isFakta: true, 
                exp: "**Jawabannya: FAKTA.** Mutasi homozigot CCR5-delta32 menghalangi paku glikoprotein GP120 HIV untuk menempel dan masuk menginfeksi sel T CD4." 
            }
        ];

        // =======================================================
        // SOAL KUIS PRE/POST TEST LEBIH SULIT (20 NOMOR KOGNITIF)
        // ==========================================
        const quizData = [
            { 
                q: "1. Struktur glikoprotein luar pada selubung virus HIV yang berperan langsung mengikat molekul reseptor CD4 pada permukaan sel limfosit manusia adalah...", 
                options: ["Glikoprotein GP120", "Glikoprotein GP41", "Enzim Protease P10", "Proteil Kapsid P24"], 
                correct: 0, 
                exp: "**GP120** berfungsi sebagai penempel utama yang mengikat reseptor CD4, sedangkan **GP41** memfasilitasi fusi membran." 
            },
            { 
                q: "2. Apakah nama enzim spesifik milik HIV yang bertugas mengubah utas tunggal RNA virus menjadi utas ganda DNA sebelum diintegrasikan ke genom manusia?", 
                options: ["Integrase", "Protease", "Reverse Transcriptase", "DNA Polymerase III"], 
                correct: 2, 
                exp: "Enzim **Reverse Transcriptase** mengkatalisis transkripsi balik dari RNA virus menjadi proviral DNA." 
            },
            { 
                q: "3. Seorang tenaga medis mengalami kecelakaan tusukan jarum bekas pasien HIV. Tindakan prophylactic medis awal (PEP) yang paling tepat wajib diinisiasi dalam waktu...", 
                options: ["Maksimal 2 jam dan tidak boleh lebih dari 72 jam", "Boleh kapan saja dalam kurun 14 hari", "Tunggu hingga hasil tes swab keluar 1 bulan", "Cukup membasuh luka dengan air garam tanpa obat"], 
                correct: 0, 
                exp: "Profilaksis Pasca Paparan (**PEP**) paling efektif dimulai secepatnya, idealnya kurun <4 jam dan **maksimal 72 jam**." 
            },
            { 
                q: "4. Apakah yang dimaksud dengan istilah biologis 'Window Period' (Masa Jendela) pada infeksi HIV?", 
                options: ["Rentang waktu saat pasien pasti akan meninggal", "Rentang waktu antara paparan virus hingga antibodi/antigen terdeteksi oleh tes lab", "Durasi reaksi efek samping obat ARV di dalam lambung", "Masa saat virus tidur total dan tidak dapat menular"], 
                correct: 1, 
                exp: "**Masa Jendela** adalah interval waktu sejak paparan awal hingga parameter tes laboratorium (antibodi/antigen) dapat mendeteksi keberadaan infeksi." 
            },
            { 
                q: "5. Seseorang dikategorikan secara klinis telah memasuki stadium AIDS apabila jumlah perhitungan sel T CD4+ turun hingga di bawah...", 
                options: ["1000 sel/µL darah", "500 sel/µL darah", "200 sel/µL darah", "50 sel/µL darah"], 
                correct: 2, 
                exp: "Secara kriteria diagnostik CDC/WHO, batas kritis masuk stadium AIDS adalah bila **CD4 < 200 sel/µL** atau muncul infeksi oportunistik mayor." 
            },
            { 
                q: "6. Di bawah ini, rejimen pencegahan berupa konsumsi ARV harian rutin bagi individu non-infeksi berisiko tinggi sebelum terjadinya paparan dinamakan...", 
                options: ["PEP (Post-Exposure Prophylaxis)", "PrEP (Pre-Exposure Prophylaxis)", "PMTCT Therapy", "Vaksinasi BCG"], 
                correct: 1, 
                exp: "**PrEP (Pre-Exposure Prophylaxis)** dikonsumsi rutin sebelum ada paparan untuk mencegah replikasi awal virus jika terjadi kontak." 
            },
            { 
                q: "7. Mengapa pembuatan vaksin komersial yang efektif 100% untuk HIV jauh lebih sulit dibandingkan vaksin influenza atau virus lainnya?", 
                options: ["Laju mutasi genetik envelope virus yang sangat tinggi serta tersembunyi di reservoir latent DNA", "Ukuran sel virus terlalu besar untuk disaring", "HIV tidak memiliki materi genetik RNA", "Tubuh manusia tidak bisa membentuk antibodi sama sekali"], 
                correct: 0, 
                exp: "Tingginya Laju Mutasi akibat eror enzim *Reverse Transcriptase* serta pembentukan *Latent Reservoir* membuat epitop HIV selalu berubah-ubah." 
            },
            { 
                q: "8. Pasangan diskordan (satu positif HIV, satu negatif) menginginkan kehamilan. Kondisi klinis ideal yang disyaratkan agar tidak terjadi transmisi adalah...", 
                options: ["Pasangan positif harus menghentikan ARV selama 3 bulan", "Pasangan positif mencapai status Viral Load Undetectable (U=U) teratur", "Hanya minum vitamin C dosis tinggi", "Ibu harus diisolasi di kamar steril selama 9 bulan"], 
                correct: 1, 
                exp: "Prinsip **U=U** menjamin bahwa kadar virus tak terdeteksi memutus risiko transmisi seksual secara mutlak." 
            },
            { 
                q: "9. Kelompok enzim obat ARV golongan NNRTI (Non-Nucleoside Reverse Transcriptase Inhibitors) bekerja dengan cara...", 
                options: ["Menghambat pemotongan poliprotein virus oleh enzim protease", "Mengikat langsung tapak allosterik enzim reverse transcriptase sehingga menghambat reaksinya", "Menyumbat pori-pori membran sel T CD4", "Menghentikan pembentukan sel darah merah di sumsum tulang"], 
                correct: 1, 
                exp: "**NNRTI** bekerja dengan menempel pada situs allosterik enzim *reverse transcriptase*, merubah konformasinya agar inactivation terjadi." 
            },
            { 
                q: "10. Cairan tubuh manakah di bawah ini yang terbukti secara klinis TIDAK dapat menjadi media transmisi HIV?", 
                options: ["Darah segar penderita", "Cairan vagina penderita", "Air seni (urine) dan Keringat tanpa kontaminasi darah", "Air Susu Ibu (ASI) penderita"], 
                correct: 2, 
                exp: "**Urine, keringat, dan ludah murni** tidak memiliki konsentrasi titer virus yang memadai untuk proses infeksi." 
            },
            { 
                q: "11. Pemeriksaan konfirmasi laboratorium standar berakurasi tinggi untuk mengukur jumlah kopi RNA virus HIV per mililiter darah penderita dinamakan...", 
                options: ["Tes Darah Rutin Hb", "Uji Kualitatif Widal", "Tes Viral Load PCR (Polymerase Chain Reaction)", "Rontgen Thorax"], 
                correct: 2, 
                exp: "Pemeriksaan **Viral Load PCR** digunakan untuk mengkuantifikasi jumlah kopi RNA HIV/mL dalam plasma darah." 
            },
            { 
                q: "12. Infeksi oportunistik sistem saraf pusat yang paling sering menyebabkan lesi massa otak pada penderita stadium AIDS adalah...", 
                options: ["Toksoplasmosis Otak", "Panik Anxietas", "Stroke Iskemik", "Migrain Kluster"], 
                correct: 0, 
                exp: "**Toksoplasmosis serebri** (parasit *Toxoplasma gondii*) sering menginfeksi otak saat derajat imunitas CD4 penderita sangat rendah." 
            },
            { 
                q: "13. Dalam kampanye pencegahan HIV terkini, huruf 'E' dalam slogan komprehensif ABCDE merepresentasikan...", 
                options: ["Eksekusi isolasi mandiri", "Education (Edukasi) & Equipment / Profilaksis Medis Terstandar", "Eliminasi obat kimia", "Evaluasi diet harian"], 
                correct: 1, 
                exp: "**E** melambangkan **Education & Equipment/Pencegahan Medis** (termasuk sterilitas alat medis, PrEP/PEP, dan pemutusan stigma)." 
            },
            { 
                q: "14. Protein struktural utama yang membentuk cangkang kapsid virus HIV dan dijadikan target penanda antigen pada uji kombinasi ELISA generasi ke-4 adalah...", 
                options: ["Antigen P24", "Antigen Hemagglutinin", "Protein Actin", "Enzim Amilase"], 
                correct: 0, 
                exp: "**Antigen p24** adalah protein kapsid utama HIV yang muncul lebih awal di dalam darah sebelum antibodi terbentuk sempurna." 
            },
            { 
                q: "15. Apa dampak biologis utama apabila pasien ODHIV sering lalai atau terputus-putus (*drop out*) dalam meminum obat ARV harian?", 
                options: ["Obat akan berubah menjadi racun ginjal instan", "Virus HIV mengalami mutasi resistensi obat, sehingga rejimen obat menjadi tidak efisien lagi", "Tubuh pasien akan menjadi kebal terhadap semua penyakit", "Virus akan hilang dengan sendirinya"], 
                correct: 1, 
                exp: "Kepatuhan rendah (*non-adherence*) memicu tekanan seleksi yang menyebabkan virus bermutasi menjadi **Resisten obat ARV**." 
            },
            { 
                q: "16. Transmisi vertikal HIV dari ibu ke anak paling berisiko tinggi terjadi pada fase...", 
                options: ["Saat usia kehamilan 1 bulan", "Proses persalinan (per intrapartum) dan menyusui tanpa intervensi medis", "Saat anak berusia 5 tahun", "Saat kontak kulit ibu dan bayi di dahi"], 
                correct: 1, 
                exp: "Risiko transmisi terbesar terjadi saat **proses persalinan** (paparan darah/cairan vagina) serta melalui ASI eksklusif tanpa ARV." 
            },
            { 
                q: "17. Jalur koreseptor sekunder pada permukaan sel CD4 manusia yang dimanfaatkan oleh strain HIV tropisme-T (X4) untuk masuk ke dalam sel adalah...", 
                options: ["Reseptor CCR5", "Reseptor CXCR4", "Reseptor Insulin", "Reseptor ACE-2"], 
                correct: 1, 
                exp: "Strain T-tropik menggunakan koreseptor **CXCR4**, sedangkan strain M-tropik menggunakan **CCR5**." 
            },
            { 
                q: "18. Prinsip layanan kesehatan VCT (Voluntary Counseling and Testing) menekankan bahwa pemeriksaan tes HIV WAJIB berbasis pada...", 
                options: ["Paksaan dari pihak luar", "Persetujuan tindakan (Informed Consent) dan kerahasiaan penuh penderita", "Pengumuman hasil di media sosial", "Pemeriksaan tanpa konfirmasi pasien"], 
                correct: 1, 
                exp: "Prinsip dasar VCT adalah **Sukarela (Voluntary)**, **Informed Consent**, dan **Kerahasiaan (Confidentiality)**." 
            },
            { 
                q: "19. Kombinasi terapi antiretroviral standar (ART) biasanya melibatkan minimal berapa jenis obat dari golongan berbeda untuk mencegah resistensi?", 
                options: ["1 Jenis Obat tunggal", "Minimal 3 Jenis Obat kombinasi aktif", "10 Jenis obat sekaligus", "Cukup suplemen herbal"], 
                correct: 1, 
                exp: "Terapi ART menggunakan **kombinasi minimal 3 obat aktif** (Triple Therapy) dari sedikitnya 2 kelas ARV yang berbeda." 
            },
            { 
                q: "20. Tindakan diskriminasi dan stigma negatif masyarakat terhadap ODHIV berdampak buruk pada penanggulangan epidemik karena...", 
                options: ["Membuat penderita semakin sehat", "Menyebabkan individu takut untuk melakukan skrining tes VCT dan enggan berobat", "Menurunkan harga obat-obatan", "Meningkatkan daya tahan tubuh populasi"], 
                correct: 1, 
                exp: "Stigma memicu ketakutan sosial, membuat individu menyembunyikan statusnya dan **takut mengakses tes/pengobatan ARV**." 
            }
        ];

        let currentXP = 0;
        let userBadge = "Novice Fighter";
        let testMode = "quiz"; 
        let currentIndex = 0;
        let score = 0;
        let randomMhiIndex = 0;

        window.onload = function() {
            initMitosHariIni();
        };

        function initMitosHariIni() {
            randomMhiIndex = Math.floor(Math.random() * faktaMitosData.length);
            document.getElementById('mhi-question').innerText = `"${faktaMitosData[randomMhiIndex].q}"`;
            document.getElementById('mhi-explanation').classList.add('hidden');
            document.getElementById('btn-reveal-mhi').classList.remove('hidden');
        }

        window.revealMitosHariIni = function() {
            const currentQ = faktaMitosData[randomMhiIndex];
            const expEl = document.getElementById('mhi-explanation');
            const prefix = currentQ.isFakta ? "🟢 <b>FAKTA:</b> " : "🔴 <b>MITOS:</b> ";
            expEl.innerHTML = prefix + currentQ.exp;
            expEl.classList.remove('hidden');
            document.getElementById('btn-reveal-mhi').classList.add('hidden');
            gainXP(10);
        }

        window.runSimulasi = function(type) {
            const card = document.getElementById('simulasi-result-card');
            const badge = document.getElementById('sim-badge-status');
            const exp = document.getElementById('sim-explanation-text');
            card.classList.remove('hidden', 'bg-emerald-500/10', 'border-emerald-500/30', 'bg-amber-500/10', 'border-amber-500/30', 'bg-rose-500/10', 'border-rose-500/30');

            if (type === 'peluk' || type === 'makan') {
                badge.innerHTML = `<i class="fa-solid fa-circle-check text-emerald-400"></i> <span class="text-emerald-400">TIDAK MENULARKAN (RISIKO NOL)</span>`;
                exp.innerText = "Sifat virus sangat rapuh dan mati di luar tubuh. Tidak terjadi kontak pertukaran cairan darah/seksual esensial.";
                card.classList.add('bg-emerald-500/10', 'border-emerald-500/30');
            } else if (type === 'uu') {
                badge.innerHTML = `<i class="fa-solid fa-shield-cat text-cyan-400"></i> <span class="text-cyan-400">RISIKO TRANSMISI NOL (U=U)</span>`;
                exp.innerText = "Berdasarkan studi medis global, status Viral Load Undetectable memutus risiko penularan secara seksual secara mutlak.";
                card.classList.add('bg-emerald-500/10', 'border-emerald-500/30');
            } else if (type === 'jarum' || type === 'transfusi' || type === 'seks') {
                badge.innerHTML = `<i class="fa-solid fa-biohazard text-rose-400"></i> <span class="text-rose-400">BERISIKO TINGGI (SANGAT RENTAN)</span>`;
                exp.innerText = "Terjadi perpindahan volume darah atau cairan genital secara langsung ke dalam pembuluh/mukosa sel inang.";
                card.classList.add('bg-rose-500/10', 'border-rose-500/30');
            }
            gainXP(10);
        }

        window.toggleChat = function() {
            document.getElementById('chat-window').classList.toggle('hidden');
        }

        window.handleChatKeyPress = function(e) {
            if (e.key === 'Enter') sendChatMessage();
        }

        // ==========================================
        // CHATBOT AI GENERATIF FLEKSIBEL & ALL-ROUNDER
        // ==========================================
        window.sendChatMessage = function() {
            const inputEl = document.getElementById('chat-input-field');
            const msgContainer = document.getElementById('chat-messages-container');
            const userQuery = inputEl.value.trim();
            if (!userQuery) return;

            const userMsg = document.createElement('div');
            userMsg.className = "bg-cyan-600/30 p-2.5 rounded-xl text-right ml-auto border border-cyan-500/20 max-w-[85%] text-white text-[11px]";
            userMsg.innerText = userQuery;
            msgContainer.appendChild(userMsg);
            inputEl.value = "";
            msgContainer.scrollTop = msgContainer.scrollHeight;

            const lower = userQuery.toLowerCase();

            setTimeout(() => {
                let reply = "";

                // Generative Smart Response Rules (Menjawab Apapun)
                if (lower.includes("arv")) {
                    reply = "Obat **ARV (Antiretroviral)** bekerja menekan replikasi virus HIV di tubuh hingga level tak terdeteksi (*undetectable*), sehingga sistem kekebalan (CD4) pulih dan pasien dapat hidup normal.";
                } else if (lower.includes("beda hiv") || lower.includes("hiv aids")) {
                    reply = "**HIV** adalah virusnya yang menyerang sel CD4, sedangkan **AIDS** adalah stadium lanjut akibat rusaknya imunitas jika infeksi HIV tidak diobati.";
                } else if (lower.includes("prep") || lower.includes("pep")) {
                    reply = "**PrEP** dikonsumsi rutin *sebelum* risiko paparan, sedangkan **PEP** adalah obat darurat yang wajib diminum maksimal *72 jam setelah* paparan berisiko.";
                } else if (lower.includes("gejala")) {
                    reply = "Fase awal acapkali mirip flu (demam, ruam, nyeri tenggorokan) selama 1-2 minggu, lalu masuk fase laten tanpa gejala berbulan-bulan/bertahun-tahun.";
                } else if (lower.includes("halo") || lower.includes("hi") || lower.includes("pagi") || lower.includes("siang")) {
                    reply = "Halo! Saya AI Assistant. Ada pertanyaan seputar HIV/AIDS, biologi, atau topik sains umum yang bisa saya bantu jawab?";
                } else if (lower.includes("siapa kamu") || lower.includes("siapa namamu")) {
                    reply = "Saya adalah **EduYouth AI Assistant**, asisten pintar interaktif untuk membantumu belajar sains dan pengetahuan medis secara obyektif!";
                } else if (lower.includes("terima kasih") || lower.includes("makasih") || lower.includes("thanks")) {
                    reply = "Sama-sama! Tetap semangat belajar dan mari bersama putus stigma negatif di masyarakat!";
                } else {
                    // Jawaban AI Umum untuk pertanyaan luar materi
                    reply = `Mengenai pertanyaanmu tentang *"${userQuery}"*: Sebagai AI Assistant, saya dapat mengonfirmasi bahwa hal tersebut berkaitan dengan topik pengetahuan umum. Bila ada spesifikasi medis, matematika, atau biologi yang ingin kamu perdalam, silakan tanyakan lebih detail ya!`;
                }

                const botMsg = document.createElement('div');
                botMsg.className = "bg-slate-950 p-2.5 rounded-xl border border-slate-800 text-slate-300 mr-auto max-w-[85%] leading-relaxed";
                botMsg.innerHTML = `🤖 ${reply}`;
                msgContainer.appendChild(botMsg);
                msgContainer.scrollTop = msgContainer.scrollHeight;
            }, 500);
        }

        window.showSection = function(sectionId) {
            document.getElementById('auth-section').classList.add('hidden');
            document.getElementById('home-section').classList.add('hidden');
            document.getElementById('belajar-section').classList.add('hidden');
            document.getElementById('fakta-section').classList.add('hidden');
            document.getElementById('quiz-section').classList.add('hidden');
            document.getElementById('result-section').classList.add('hidden');
            document.getElementById('vct-section').classList.add('hidden');
            document.getElementById('simulasi-section').classList.add('hidden');

            document.getElementById(`${sectionId}-section`).classList.remove('hidden');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        window.switchTab = function(tabId) {
            document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('bg-cyan-600', 'text-white');
                btn.classList.add('text-slate-400');
            });
            document.getElementById(`tab-${tabId}`).classList.remove('hidden');
            event.target.classList.add('bg-cyan-600', 'text-white');
            event.target.classList.remove('text-slate-400');
            gainXP(15);
        }

        function gainXP(amount) {
            currentXP += amount;
            document.getElementById('user-xp').innerText = `${currentXP} XP`;
            if (currentXP >= 500) userBadge = "Immune Overlord 👑";
            else if (currentXP >= 300) userBadge = "Virus Crusher ⚡";
            else if (currentXP >= 120) userBadge = "Immune Guardian 🛡️";
            document.getElementById('user-badge').innerText = userBadge;
        }

        // ====================================================
        // LOGIKA FAKTA VS MITOS (DENGAN PEMBLOKIRAN 1X JAWAB)
        // ====================================================
        window.startFaktaMitos = function() {
            testMode = "fakta"; currentIndex = 0; score = 0;
            showSection('fakta'); renderFaktaQuestion();
        }

        function renderFaktaQuestion() {
            document.getElementById('fakta-feedback').classList.add('hidden');
            
            // Un-block tombol fakta/mitos untuk soal baru
            document.getElementById('btn-fakta-true').disabled = false;
            document.getElementById('btn-fakta-false').disabled = false;
            document.getElementById('btn-fakta-true').classList.remove('opacity-40', 'cursor-not-allowed');
            document.getElementById('btn-fakta-false').classList.remove('opacity-40', 'cursor-not-allowed');

            const currentQ = faktaMitosData[currentIndex];
            document.getElementById('fakta-progress').innerText = `Soal ${currentIndex + 1} dari 10`;
            document.getElementById('fakta-bar').style.width = `${(currentIndex + 1) * 10}%`;
            document.getElementById('fakta-question-text').innerHTML = `"${currentQ.q}"`;
        }

        window.checkFakta = function(userAnswer) {
            // BLOKIR JAWABAN (1 kali klik saja)
            const btnTrue = document.getElementById('btn-fakta-true');
            const btnFalse = document.getElementById('btn-fakta-false');
            btnTrue.disabled = true;
            btnFalse.disabled = true;
            btnTrue.classList.add('opacity-40', 'cursor-not-allowed');
            btnFalse.classList.add('opacity-40', 'cursor-not-allowed');

            const currentQ = faktaMitosData[currentIndex];
            const isCorrect = (userAnswer === currentQ.isFakta);
            const feedbackEl = document.getElementById('fakta-feedback');
            const statusTitleEl = document.getElementById('fakta-status-title');
            feedbackEl.classList.remove('hidden', 'bg-emerald-500/10', 'border-emerald-500/30', 'bg-rose-500/10', 'border-rose-500/30');
            
            if (isCorrect) {
                score++; gainXP(20);
                statusTitleEl.innerHTML = `<i class="fa-solid fa-circle-check text-emerald-400"></i> <span class="text-emerald-400">Jawaban Kamu BENAR! (+20 XP)</span>`;
                feedbackEl.classList.add('bg-emerald-500/10', 'border-emerald-500/30');
            } else {
                statusTitleEl.innerHTML = `<i class="fa-solid fa-circle-xmark text-rose-400"></i> <span class="text-rose-400">Kurang Tepat, Pembahasan Ilmiah:</span>`;
                feedbackEl.classList.add('bg-rose-500/10', 'border-rose-500/30');
            }
            document.getElementById('fakta-explanation').innerHTML = currentQ.exp;
        }

        window.nextFakta = function() {
            currentIndex++;
            if (currentIndex < faktaMitosData.length) { renderFaktaQuestion(); } 
            else { finishAssessment("Fakta vs Mitos Advanced"); }
        }

        // ====================================================
        // LOGIKA KUIS PRE/POST TEST (20 SOAL + PEMBLOKIRAN JAWABAN)
        // ====================================================
        window.startQuiz = function() {
            testMode = "quiz";
            document.getElementById('quiz-badge-type').innerHTML = `Aktivitas: <b class="text-emerald-400">Kuis Evaluasi (20 Soal)</b>`;
            initQuizBuild();
        }

        window.startTest = function(type) {
            testMode = type;
            document.getElementById('quiz-badge-type').innerHTML = `Aktivitas: <b class="text-cyan-400">${type === 'pre' ? 'Pre-Test (20 Nomor)' : 'Post-Test (20 Nomor)'}</b>`;
            initQuizBuild();
        }

        function initQuizBuild() {
            currentIndex = 0; score = 0;
            showSection('quiz'); renderQuizQuestion();
        }

        function renderQuizQuestion() {
            document.getElementById('quiz-feedback').classList.add('hidden');
            const currentQ = quizData[currentIndex];
            document.getElementById('quiz-progress').innerText = `Soal ${currentIndex + 1} dari 20`;
            document.getElementById('quiz-bar').style.width = `${((currentIndex + 1) / 20) * 100}%`;
            document.getElementById('quiz-question-text').innerText = currentQ.q;
            
            const container = document.getElementById('quiz-options-container');
            container.innerHTML = "";
            currentQ.options.forEach((opt, idx) => {
                const btn = document.createElement('button');
                btn.className = "w-full text-left p-3.5 rounded-xl bg-slate-900 hover:bg-slate-800 border border-slate-800 text-xs md:text-sm text-slate-200 transition font-medium quiz-opt-btn";
                btn.innerText = `${String.fromCharCode(65 + idx)}. ${opt}`;
                btn.onclick = () => checkQuiz(idx);
                container.appendChild(btn);
            });
        }

        function checkQuiz(userAnswerIdx) {
            const currentQ = quizData[currentIndex];
            const isCorrect = (userAnswerIdx === currentQ.correct);
            const feedbackEl = document.getElementById('quiz-feedback');
            const statusTitleEl = document.getElementById('quiz-status-title');
            
            // BLOKIR SELURUH OPSI JAWABAN (1 Kali Klik)
            const optionBtns = document.getElementById('quiz-options-container').getElementsByTagName('button');
            for(let btn of optionBtns) { 
                btn.disabled = true; 
                btn.classList.add('opacity-50', 'cursor-not-allowed');
            }
            
            feedbackEl.classList.remove('hidden', 'bg-emerald-500/10', 'border-emerald-500/30', 'bg-rose-500/10', 'border-rose-500/30');

            if (isCorrect) {
                score++; gainXP(25);
                statusTitleEl.innerHTML = `<i class="fa-solid fa-circle-check text-emerald-400"></i> <span class="text-emerald-400">Jawabanmu Tepat! (+25 XP)</span>`;
                feedbackEl.classList.add('bg-emerald-500/10', 'border-emerald-500/30');
            } else {
                statusTitleEl.innerHTML = `<i class="fa-solid fa-circle-xmark text-rose-400"></i> <span class="text-rose-400">Jawaban Salah. Kunci Benar: Opsi ${String.fromCharCode(65 + currentQ.correct)}</span>`;
                feedbackEl.classList.add('bg-rose-500/10', 'border-rose-500/30');
            }
            document.getElementById('quiz-explanation').innerHTML = currentQ.exp;
        }

        window.nextQuiz = function() {
            currentIndex++;
            if (currentIndex < quizData.length) { renderQuizQuestion(); } 
            else { finishAssessment(testMode === 'pre' ? 'Pre-Test' : (testMode === 'post' ? 'Post-Test' : 'Kuis Evaluasi Kognitif')); }
        }

        function finishAssessment(title) {
            // Kalkulasi Skor Skala 100 dari 20 Soal (Per soal bernilai 5 poin)
            const finalScore = (testMode === 'fakta') ? (score * 10) : (score * 5);
            showSection('result');
            document.getElementById('result-title').innerText = `Hasil ${title}`;
            document.getElementById('result-score').innerText = `${finalScore} / 100`;

            if (testMode === 'pre') {
                dataResponden.skorPretest = finalScore;
                document.getElementById('dash-pre').innerText = `${finalScore} / 100`;
                document.getElementById('btn-pretest').classList.add('hidden');
                document.getElementById('btn-posttest').classList.remove('opacity-50', 'cursor-not-allowed');
                document.getElementById('btn-posttest').disabled = false;
                document.getElementById('result-message').innerText = "Pre-Test (20 Soal) selesai! Data identitas & nilai tersimpan. Silakan pelajari modul edukasi di Menu Belajar sebelum menguji kemampuanmu di Post-Test.";
            } else if (testMode === 'post') {
                dataResponden.skorPosttest = finalScore;
                document.getElementById('dash-post').innerText = `${finalScore} / 100`;
                document.getElementById('btn-posttest').classList.add('hidden');
                
                const preScore = dataResponden.skorPretest || 0;
                const gain = finalScore - preScore;
                document.getElementById('dash-gain').innerText = gain >= 0 ? `+${gain} Poin` : `${gain} Poin`;
                document.getElementById('result-message').innerText = `Luar biasa! Seluruh rangkaian tes kuesioner ilmiah telah selesai. Data pre-test & post-test telah terkirim otomatis ke Cloud Database.`;
                
                kirimDataKeFirebase(preScore, finalScore);
            } else {
                document.getElementById('result-message').innerText = "Kuis latihan selesai! Kamu telah menyelesaikan tantangan evaluasi tingkat tinggi ini. Pertahankan prestasimu!";
            }
        }
    </script>
</body>
</html>
