<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HIV/AIDS Smart Education Awareness</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .gradient-bg { background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%); }
        .card-glow { box-shadow: 0 0 20px rgba(99, 102, 241, 0.15); }
        .anim-float { animation: float 3s ease-in-out infinite; }
        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
    </style>
</head>
<body class="bg-slate-900 text-slate-100 min-h-screen flex flex-col">

    <nav class="bg-slate-900/80 backdrop-blur-md sticky top-0 z-50 border-b border-slate-800 px-4 py-3">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <div class="flex items-center gap-2 cursor-pointer" onclick="showSection('home')">
                <div class="w-10 h-10 bg-indigo-600 rounded-xl flex items-center justify-center text-white font-bold text-xl shadow-lg shadow-indigo-500/30">
                    <i class="fa-solid fa-shield-virus"></i>
                </div>
                <span class="font-bold text-lg bg-gradient-to-r content-box from-indigo-400 to-pink-500 bg-clip-text text-transparent">EduYouth HIV</span>
            </div>
            
            <div class="flex items-center gap-4 bg-slate-800/80 px-4 py-1.5 rounded-full border border-slate-700">
                <div class="flex items-center gap-1.5 text-amber-400">
                    <i class="fa-solid fa-star text-sm"></i>
                    <span id="user-xp" class="font-bold text-sm">0 XP</span>
                </div>
                <div class="h-4 w-px bg-slate-700"></div>
                <div class="flex items-center gap-1.5 text-pink-400">
                    <i class="fa-solid fa-medal text-sm"></i>
                    <span id="user-badge" class="font-bold text-xs">Novice Fighter</span>
                </div>
            </div>
        </div>
    </nav>

    <main class="flex-1 max-w-5xl w-full mx-auto p-4 md:p-6 pb-24">
        
        <!-- SECTION 0: FORM IDENTITAS RESPONDEN -->
        <section id="auth-section" class="hidden space-y-6 animate-fade-in max-w-md mx-auto py-8">
            <div class="bg-slate-800/90 border border-indigo-500/30 p-6 rounded-2xl card-glow space-y-4">
                <div class="text-center space-y-1">
                    <h2 class="text-xl font-bold text-white flex items-center justify-center gap-2">
                        <i class="fa-solid fa-user-pen text-indigo-400"></i> Identitas Responden
                    </h2>
                    <p class="text-xs text-slate-400">Silakan isi data diri sebelum memulai Pre-Test kuesioner penelitian.</p>
                </div>
                <hr class="border-slate-700">
                <div class="space-y-3">
                    <div>
                        <label class="block text-xs font-semibold text-slate-300 mb-1">Nama Lengkap</label>
                        <input type="text" id="input-nama" placeholder="Masukkan Nama Lengkap" class="w-full bg-slate-900 border border-slate-700 rounded-xl px-3 py-2 text-sm text-white focus:outline-none focus:border-indigo-500">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-300 mb-1">Umur (Tahun)</label>
                        <input type="number" id="input-umur" placeholder="Contoh: 17" class="w-full bg-slate-900 border border-slate-700 rounded-xl px-3 py-2 text-sm text-white focus:outline-none focus:border-indigo-500">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-300 mb-1">Asal Sekolah / Instansi</label>
                        <input type="text" id="input-sekolah" placeholder="Contoh: SMAN 1" class="w-full bg-slate-900 border border-slate-700 rounded-xl px-3 py-2 text-sm text-white focus:outline-none focus:border-indigo-500">
                    </div>
                    <div class="pt-2">
                        <label class="flex items-start gap-2.5 cursor-pointer">
                            <input type="checkbox" id="input-persetujuan" class="mt-0.5 rounded border-slate-700 bg-slate-900 text-indigo-600 focus:ring-0">
                            <span class="text-[11px] text-slate-400 leading-tight">Saya bersedia data pengisian instrumen ini digunakan untuk keperluan analisis laporan penelitian ilmiah secara anonim.</span>
                        </label>
                    </div>
                </div>
                <button onclick="submitIdentitas()" class="w-full bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-2.5 rounded-xl text-sm transition shadow-lg shadow-indigo-600/20">
                    Simpan & Mulai Ujian <i class="fa-solid fa-arrow-right ml-1"></i>
                </button>
            </div>
        </section>

        <!-- SECTION 1: HOME -->
        <section id="home-section" class="space-y-8 animate-fade-in">
            <div class="text-center space-y-4 py-8">
                <span class="px-4 py-1.5 rounded-full bg-indigo-500/10 text-indigo-400 text-xs font-semibold uppercase tracking-wider border border-indigo-500/20">Media Edukasi Interaktif Generasi Muda</span>
                <h1 class="text-4xl md:text-5xl font-extrabold text-white tracking-tight">Putus Stigma, <br class="md:hidden"><span class="bg-gradient-to-r from-indigo-400 via-purple-400 to-pink-500 bg-clip-text text-transparent">Sambung Wawasan Seputar HIV/AIDS</span></h1>
                <p class="text-slate-400 max-w-xl mx-auto text-sm md:text-base">Aplikasi belajar interaktif yang dikembangkan khusus remaja untuk memahami HIV/AIDS secara objektif, ilmiah, dan seru.</p>
            </div>

            <!-- MITOS HARI INI -->
            <div class="bg-slate-800/90 border border-amber-500/30 p-5 rounded-2xl card-glow relative overflow-hidden">
                <div class="absolute top-0 right-0 p-3 opacity-10 text-6xl text-amber-400"><i class="fa-solid fa-dice"></i></div>
                <div class="flex items-center gap-2 text-amber-400 font-bold text-sm mb-2">
                    <i class="fa-solid fa-bolt"></i> <span>Mitos Hari Ini (Asah Otak Instan)</span>
                </div>
                <div id="mitos-hari-ini-body" class="space-y-3">
                    <p id="mhi-question" class="text-sm font-semibold text-white italic">"Loading mitos unik..."</p>
                    <button onclick="revealMitosHariIni()" id="btn-reveal-mhi" class="bg-amber-500 hover:bg-amber-400 text-slate-900 font-bold text-xs px-3 py-1.5 rounded-lg transition">
                        <i class="fa-solid fa-eye mr-1"></i> Cek Faktanya
                    </button>
                    <p id="mhi-explanation" class="hidden text-xs text-slate-300 bg-slate-900/60 p-3 rounded-xl border border-slate-700 leading-relaxed"></p>
                </div>
            </div>

            <!-- LKTI TRACKER -->
            <div class="bg-gradient-to-r from-indigo-900/40 to-slate-800/80 p-6 rounded-2xl border border-indigo-500/30 card-glow flex flex-col md:flex-row justify-between items-center gap-4">
                <div class="space-y-1 text-center md:text-left">
                    <h3 class="font-bold text-lg text-white flex items-center gap-2 justify-center md:justify-start">
                        <i class="fa-solid fa-chart-line text-indigo-400"></i> Tolok Ukur Pengetahuan (LKTI Tracker)
                    </h3>
                    <p class="text-xs text-slate-400">Uji pemahamanmu sebelum dan sesudah belajar untuk melihat grafik kenaikan ilmumu.</p>
                </div>
                <div class="flex gap-3 w-full md:w-auto">
                    <button onclick="bukaFormIdentitasOrStart()" id="btn-pretest" class="flex-1 md:flex-initial bg-indigo-600 hover:bg-indigo-500 text-white px-5 py-2.5 rounded-xl font-bold text-sm transition shadow-lg shadow-indigo-600/20 whitespace-nowrap"><i class="fa-solid fa-play mr-2"></i>Mulai Pre-Test</button>
                    <button onclick="startTest('post')" id="btn-posttest" class="flex-1 md:flex-initial bg-slate-700 opacity-50 cursor-not-allowed text-white px-5 py-2.5 rounded-xl font-bold text-sm transition whitespace-nowrap" disabled><i class="fa-solid fa-graduation-cap mr-2"></i>Mulai Post-Test</button>
                </div>
            </div>

            <!-- SKOR BOX -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="bg-slate-800/60 p-5 rounded-2xl border border-slate-700/80 flex items-center gap-4">
                    <div class="w-12 h-12 rounded-xl bg-indigo-500/10 flex items-center justify-center text-indigo-400 text-xl"><i class="fa-solid fa-bullseye"></i></div>
                    <div>
                        <div class="text-xs text-slate-400">Skor Pre-Test</div>
                        <div id="dash-pre" class="text-xl font-bold text-white">-</div>
                    </div>
                </div>
                <div class="bg-slate-800/60 p-5 rounded-2xl border border-slate-700/80 flex items-center gap-4">
                    <div class="w-12 h-12 rounded-xl bg-pink-500/10 flex items-center justify-center text-pink-400 text-xl"><i class="fa-solid fa-trophy"></i></div>
                    <div>
                        <div class="text-xs text-slate-400">Skor Post-Test</div>
                        <div id="dash-post" class="text-xl font-bold text-white">-</div>
                    </div>
                </div>
                <div class="bg-slate-800/60 p-5 rounded-2xl border border-slate-700/80 flex items-center gap-4">
                    <div class="w-12 h-12 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-400 text-xl"><i class="fa-solid fa-arrow-trend-up"></i></div>
                    <div>
                        <div class="text-xs text-slate-400">Efektivitas Belajar</div>
                        <div id="dash-gain" class="text-xl font-bold text-emerald-400">-</div>
                    </div>
                </div>
            </div>

            <!-- MENU UTAMA CARD -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 pt-2">
                <button onclick="showSection('belajar')" class="p-5 text-left bg-slate-800 hover:bg-slate-700/80 rounded-2xl border border-slate-700 transition duration-300 group">
                    <div class="w-12 h-12 rounded-xl bg-indigo-500/10 flex items-center justify-center text-indigo-400 text-xl mb-4 group-hover:scale-110 transition"><i class="fa-solid fa-book-open"></i></div>
                    <h4 class="font-bold text-white mb-1">Menu Belajar</h4>
                    <p class="text-xs text-slate-400">Pelajari materi HIV, imun, penularan, dan pencegahan secara interaktif.</p>
                </button>
                <button onclick="startFaktaMitos()" class="p-5 text-left bg-slate-800 hover:bg-slate-700/80 rounded-2xl border border-slate-700 transition duration-300 group">
                    <div class="w-12 h-12 rounded-xl bg-amber-500/10 flex items-center justify-center text-amber-400 text-xl mb-4 group-hover:scale-110 transition"><i class="fa-solid fa-circle-question"></i></div>
                    <h4 class="font-bold text-white mb-1">Fakta vs Mitos</h4>
                    <p class="text-xs text-slate-400">Uji 10 mitos populer yang sering salah dipahami masyarakat luas.</p>
                </button>
                <button onclick="startQuiz()" class="p-5 text-left bg-slate-800 hover:bg-slate-700/80 rounded-2xl border border-slate-700 transition duration-300 group">
                    <div class="w-12 h-12 rounded-xl bg-pink-500/10 flex items-center justify-center text-pink-400 text-xl mb-4 group-hover:scale-110 transition"><i class="fa-solid fa-gamepad"></i></div>
                    <h4 class="font-bold text-white mb-1">Kuis Interaktif</h4>
                    <p class="text-xs text-slate-400">Tantang wawasanmu dengan 10 kuis ber-skor otomatis & naikkan XP-mu.</p>
                </button>
                <button onclick="showSection('simulasi')" class="p-5 text-left bg-slate-800 hover:bg-slate-700/80 rounded-2xl border border-slate-700 transition duration-300 group">
                    <div class="w-12 h-12 rounded-xl bg-purple-500/10 flex items-center justify-center text-purple-400 text-xl mb-4 group-hover:scale-110 transition"><i class="fa-solid fa-virus-covid"></i></div>
                    <h4 class="font-bold text-white mb-1">Simulasi Risiko</h4>
                    <p class="text-xs text-slate-400">Pilih tindakan simulasi untuk melihat kerentanan paparan virus.</p>
                </button>
                <button onclick="showSection('vct')" class="p-5 text-left bg-slate-800 hover:bg-slate-700/80 rounded-2xl border border-slate-700 transition duration-300 group">
                    <div class="w-12 h-12 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-400 text-xl mb-4 group-hover:scale-110 transition"><i class="fa-solid fa-map-location-dot"></i></div>
                    <h4 class="font-bold text-white mb-1">Layanan VCT</h4>
                    <p class="text-xs text-slate-400">Informasi rujukan layanan konseling & pemeriksaan HIV rahasia.</p>
                </button>
            </div>
        </section>

        <!-- SECTION 2: MENU BELAJAR -->
        <section id="belajar-section" class="hidden space-y-6 animate-fade-in">
            <div class="flex flex-wrap gap-2 p-1.5 bg-slate-800/80 rounded-xl border border-slate-700 overflow-x-auto">
                <button onclick="switchTab('pengertian')" class="tab-btn active-tab flex-1 min-w-[120px] px-4 py-2 rounded-lg font-bold text-xs md:text-sm text-center transition bg-indigo-600 text-white">Pengertian</button>
                <button onclick="switchTab('imun')" class="tab-btn flex-1 min-w-[120px] px-4 py-2 rounded-lg font-bold text-xs md:text-sm text-center text-slate-400 transition">Sistem Imun</button>
                <button onclick="switchTab('penularan')" class="tab-btn flex-1 min-w-[120px] px-4 py-2 rounded-lg font-bold text-xs md:text-sm text-center text-slate-400 transition">Cara Penularan</button>
                <button onclick="switchTab('pencegahan')" class="tab-btn flex-1 min-w-[120px] px-4 py-2 rounded-lg font-bold text-xs md:text-sm text-center text-slate-400 transition">Pencegahan</button>
            </div>

            <div id="tab-pengertian" class="tab-content bg-slate-800/40 p-6 rounded-2xl border border-slate-700/60 space-y-4">
                <div class="flex items-center gap-3 border-b border-slate-700 pb-3">
                    <i class="fa-solid fa-dna text-indigo-400 text-2xl"></i>
                    <h2 class="text-xl font-bold text-white">Apa sih bedanya HIV dan AIDS?</h2>
                </div>
                <p class="text-sm md:text-base leading-relaxed text-slate-300">
                    Banyak yang mengira **HIV** dan **AIDS** adalah hal yang sama persis, padahal beda level lho! 
                </p>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 pt-2">
                    <div class="p-4 bg-slate-800 rounded-xl border-l-4 border-indigo-500">
                        <span class="font-bold text-indigo-400 text-sm block mb-1">HIV (Human Immunodeficiency Virus)</span>
                        <p class="text-xs text-slate-300 leading-relaxed">Adalah **virusnya**. Nama virus yang menyerang dan melemahkan sistem kekebalan tubuh manusia. Orang yang terinfeksi disebut ODHIV (Orang Dengan HIV) dan bisa terlihat sangat sehat selama bertahun-tahun tanpa gejala luar.</p>
                    </div>
                    <div class="p-4 bg-slate-800 rounded-xl border-l-4 border-pink-500">
                        <span class="font-bold text-pink-400 text-sm block mb-1">AIDS (Acquired Immunodeficiency Syndrome)</span>
                        <p class="text-xs text-slate-300 leading-relaxed">Adalah **stadium akhir/kumpulan gejala** akibat rusaknya sistem imun oleh infeksi HIV yang tidak diobati. Di tahap ini, tubuh jadi sangat rapuh bahkan terhadap flu atau batuk ringan sekalipun.</p>
                    </div>
                </div>
            </div>

            <div id="tab-imun" class="tab-content hidden bg-slate-800/40 p-6 rounded-2xl border border-slate-700/60 space-y-4">
                <div class="flex items-center gap-3 border-b border-slate-700 pb-3">
                    <i class="fa-solid fa-shield text-emerald-400 text-2xl"></i>
                    <h2 class="text-xl font-bold text-white">Medan Perang: HIV vs Sel Darah Putih (CD4)</h2>
                </div>
                <p class="text-sm md:text-base leading-relaxed text-slate-300">
                    Sistem kekebalan tubuh kita punya "komandan jenderal" namanya **Sel T-Helper** atau sering disebut **Sel CD4**. 
                </p>
                <div class="bg-slate-800 p-4 rounded-xl flex items-start gap-3">
                    <div class="text-amber-400 text-lg mt-0.5"><i class="fa-solid fa-circle-exclamation"></i></div>
                    <p class="text-xs text-slate-300 leading-relaxed">
                        **Bagaimana HIV merusak sistem tubuh?** Virus HIV bertindak layaknya pembajak. Ia tidak hanya membunuh sel kekebalan, tetapi masuk ke dalam sel CD4, membajak mesin biologis sel tersebut untuk memperbanyak dirinya sendiri, lalu meledakkan sel tersebut dari dalam untuk menyebarkan pasukan virus baru. Akibatnya, jumlah CD4 terus turun drastis, menyisakan pertahanan tubuh yang kosong tanpa arah.
                    </p>
                </div>
            </div>

            <div id="tab-penularan" class="tab-content hidden bg-slate-800/40 p-6 rounded-2xl border border-slate-700/60 space-y-4">
                <div class="flex items-center gap-3 border-b border-slate-700 pb-3">
                    <i class="fa-solid fa-arrows-spin text-pink-400 text-2xl"></i>
                    <h2 class="text-xl font-bold text-white">Jalur Penularan (Hanya Melalui 4 Cairan Tubuh)</h2>
                </div>
                <p class="text-sm text-slate-300">HIV **TIDAK** menular lewat udara, bersentuhan, ataupun gigitan nyamuk. HIV hanya bisa bertahan hidup di dalam 4 cairan tubuh spesifik ini:</p>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                    <div class="p-3 bg-slate-800 rounded-xl text-center font-semibold text-xs border border-slate-700 text-pink-400">Darah</div>
                    <div class="p-3 bg-slate-800 rounded-xl text-center font-semibold text-xs border border-slate-700 text-indigo-400">Cairan Sperma</div>
                    <div class="p-3 bg-slate-800 rounded-xl text-center font-semibold text-xs border border-slate-700 text-purple-400">Cairan Vagina</div>
                    <div class="p-3 bg-slate-800 rounded-xl text-center font-semibold text-xs border border-slate-700 text-amber-400">Air Susu Ibu (ASI)</div>
                </div>
                <p class="text-xs text-slate-400 bg-slate-800 p-3 rounded-xl">⚠️ **Catatan Penting:** Penularan terjadi jika cairan tersebut masuk langsung ke aliran darah, misalnya lewat hubungan seksual berisiko tanpa pengaman, penggunaan jarum suntik secara bergantian (pada narkoba), atau dari ibu ke bayi saat hamil/menyusui.</p>
            </div>

            <div id="tab-pencegahan" class="tab-content hidden bg-slate-800/40 p-6 rounded-2xl border border-slate-700/60 space-y-4">
                <div class="flex items-center gap-3 border-b border-slate-700 pb-3">
                    <i class="fa-solid fa-hand-holding-hand text-cyan-400 text-2xl"></i>
                    <h2 class="text-xl font-bold text-white">Metode Pencegahan Ilmiah (ABCDE)</h2>
                </div>
                <div class="space-y-3">
                    <div class="bg-slate-800 p-3.5 rounded-xl text-xs"><b class="text-cyan-400">A - Abstinence:</b> Absen seks, artinya tidak melakukan hubungan seksual sebelum resmi menikah. (Sangat relevan untuk remaja!)</div>
                    <div class="bg-slate-800 p-3.5 rounded-xl text-xs"><b class="text-cyan-400">B - Be Faithful:</b> Saling setia pada satu pasangan resmi, tidak berganti-ganti pasangan.</div>
                    <div class="bg-slate-800 p-3.5 rounded-xl text-xs"><b class="text-cyan-400">C - Condom:</b> Penggunaan pengaman saat berhubungan berisiko tinggi.</div>
                    <div class="bg-slate-800 p-3.5 rounded-xl text-xs"><b class="text-cyan-400">D - Drug No:</b> Hindari narkoba, terutama jenis suntik yang dipakai bergantian.</div>
                    <div class="bg-slate-800 p-3.5 rounded-xl text-xs"><b class="text-cyan-400">E - Education:</b> Aktif mencari edukasi yang benar dan meluruskan stigma negatif di masyarakat.</div>
                </div>
            </div>
        </section>

        <!-- SIMULASI RISIKO PENULARAN HIV -->
        <section id="simulasi-section" class="hidden space-y-6 animate-fade-in">
            <div class="bg-slate-800/80 p-6 rounded-2xl border border-slate-700 card-glow space-y-4">
                <div class="flex items-center gap-3 border-b border-slate-700 pb-3">
                    <i class="fa-solid fa-virus-covid text-purple-400 text-2xl"></i>
                    <h2 class="text-xl font-bold text-white">Simulator Interaktif Tingkat Risiko Penularan</h2>
                </div>
                <p class="text-xs md:text-sm text-slate-300">Pilih salah satu aktivitas sosial atau klinis di bawah ini untuk menganalisis tingkat potensi penularan virus secara objektif:</p>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3" id="simulasi-options-box">
                    <button onclick="runSimulasi('peluk')" class="w-full text-left p-4 rounded-xl bg-slate-900 hover:bg-slate-700/50 border border-slate-700 text-xs md:text-sm font-medium flex justify-between items-center text-slate-100 transition">
                        <span><i class="fa-solid fa-people-arrows mr-2 text-indigo-400"></i> Berpelukan dengan ODHIV</span>
                        <i class="fa-solid fa-chevron-right text-slate-500"></i>
                    </button>
                    <button onclick="runSimulasi('cium')" class="w-full text-left p-4 rounded-xl bg-slate-900 hover:bg-slate-700/50 border border-slate-700 text-xs md:text-sm font-medium flex justify-between items-center text-slate-100 transition">
                        <span><i class="fa-solid fa-face-kiss-wink-heart mr-2 text-indigo-400"></i> Berciuman Pipi / Sosial</span>
                        <i class="fa-solid fa-chevron-right text-slate-500"></i>
                    </button>
                    <button onclick="runSimulasi('jarum')" class="w-full text-left p-4 rounded-xl bg-slate-900 hover:bg-slate-700/50 border border-slate-700 text-xs md:text-sm font-medium flex justify-between items-center text-slate-100 transition">
                        <span><i class="fa-solid fa-syringe mr-2 text-indigo-400"></i> Berbagi Jarum Suntik Bergantian</span>
                        <i class="fa-solid fa-chevron-right text-slate-500"></i>
                    </button>
                    <button onclick="runSimulasi('jabat')" class="w-full text-left p-4 rounded-xl bg-slate-900 hover:bg-slate-700/50 border border-slate-700 text-xs md:text-sm font-medium flex justify-between items-center text-slate-100 transition">
                        <span><i class="fa-solid fa-handshake mr-2 text-indigo-400"></i> Berjabat Tangan Komunitas</span>
                        <i class="fa-solid fa-chevron-right text-slate-500"></i>
                    </button>
                    <button onclick="runSimulasi('donor')" class="w-full text-left p-4 rounded-xl bg-slate-900 hover:bg-slate-700/50 border border-slate-700 text-xs md:text-sm font-medium flex justify-between items-center text-slate-100 transition">
                        <span><i class="fa-solid fa-droplet mr-2 text-indigo-400"></i> Donor Darah PMI Resmi & Aman</span>
