            },
            { 
                q: "Glikoprotein pada permukaan mantel luar virus HIV yang berfungsi untuk mengenali dan menempel pada reseptor sel CD4 manusia adalah...", 
                options: ["gp120 dan gp41", "Hemagglutinin", "Neuraminidase", "Spike Protein S1"], 
                correct: 0, 
                exp: "Kompleks tonjolan mantel HIV terdiri dari **gp120** (untuk mengikat reseptor CD4) dan **gp41** (membantu proses fusi membran)." 
            },
            { 
                q: "Terminologi medis 'Masa Jendela' (Window Period) pada infeksi HIV didefinisikan sebagai...", 
                options: ["Tenggat waktu penderita AIDS untuk sembuh total", "Rentang waktu antara paparan pertama virus hingga antibodi/antigen terdeteksi oleh alat tes", "Durasi waktu obat ARV bertahan di dalam organ ginjal", "Masa inkubasi tanpa gejala selama 20 tahun"], 
                correct: 1, 
                exp: "**Masa Jendela** adalah interval waktu antara masuknya virus ke tubuh sampai parameter pemeriksaan laboratorium dapat mendeteksi keberadaannya." 
            },
            { 
                q: "Manakah strategi pencegahan HIV yang ditujukan khusus bagi populasi berisiko tinggi sebelum terjadinya potensi paparan?", 
                options: ["PrEP (Pre-Exposure Prophylaxis)", "PEP (Post-Exposure Prophylaxis)", "PMTCT", "Vaksinasi BCG"], 
                correct: 0, 
                exp: "**PrEP** disiapkan untuk diminum *sebelum* terpapar guna mencegah penetrasi infeksi HIV pada individu berisiko tinggi." 
            },
            { 
                q: "Mengapa hingga saat ini virus HIV sangat sulit dibuatkan vaksin komersial yang mampu memberikan perlindungan 100%?", 
                options: ["Karena virus HIV ukurannya terlalu besar", "Karena laju mutasi genetik virus sangat tinggi dan cepat mengelabui sistem imun", "Karena virus HIV tidak memiliki materi genetik", "Karena virus HIV tidak bisa dibiakkan di laboratorium"], 
                correct: 1, 
                exp: "Enzim reverse transcriptase HIV tidak memiliki fungsi *proofreading* (pembetulan), menyebabkan **laju mutasi genetik yang amat tinggi**, sehingga antibodi vaksin cepat kadaluarsa." 
            }
        ];

        let currentXP = 0;
        let userBadge = "Novice Fighter";
        let testMode = "quiz"; 
        let currentIndex = 0;
        let score = 0;
        let randomMhiIndex = 0;

        window.onload = function() {
            initMitosHariIni();
        };

        function initMitosHariIni() {
            randomMhiIndex = Math.floor(Math.random() * faktaMitosData.length);
            document.getElementById('mhi-question').innerText = `"${faktaMitosData[randomMhiIndex].q}"`;
            document.getElementById('mhi-explanation').classList.add('hidden');
            document.getElementById('btn-reveal-mhi').classList.remove('hidden');
        }

        window.revealMitosHariIni = function() {
            const currentQ = faktaMitosData[randomMhiIndex];
            const expEl = document.getElementById('mhi-explanation');
            const prefix = currentQ.isFakta ? "🟢 <b>FAKTA:</b> " : "🔴 <b>MITOS:</b> ";
            expEl.innerHTML = prefix + currentQ.exp;
            expEl.classList.remove('hidden');
            document.getElementById('btn-reveal-mhi').classList.add('hidden');
            gainXP(10);
        }

        window.runSimulasi = function(type) {
            const card = document.getElementById('simulasi-result-card');
            const badge = document.getElementById('sim-badge-status');
            const exp = document.getElementById('sim-explanation-text');
            card.classList.remove('hidden', 'bg-emerald-500/10', 'border-emerald-500/30', 'bg-amber-500/10', 'border-amber-500/30', 'bg-pink-500/10', 'border-pink-500/30');

            if (type === 'peluk') {
                badge.innerHTML = `<i class="fa-solid fa-circle-check text-emerald-400"></i> <span class="text-emerald-400">TIDAK MENULARKAN</span>`;
                exp.innerText = "Sifat virus sangat rapuh dan mati seketika di permukaan kulit luar. Tidak ada pertukaran cairan esensial.";
                card.classList.add('bg-emerald-500/10', 'border-emerald-500/30');
            } else if (type === 'cium') {
                badge.innerHTML = `<i class="fa-solid fa-circle-check text-emerald-400"></i> <span class="text-emerald-400">TIDAK MENULARKAN</span>`;
                exp.innerText = "Air liur dalam kondisi ciuman pipi biasa tidak memiliki konsentrasi viral load yang cukup.";
                card.classList.add('bg-emerald-500/10', 'border-emerald-500/30');
            } else if (type === 'jabat') {
                badge.innerHTML = `<i class="fa-solid fa-circle-check text-emerald-400"></i> <span class="text-emerald-400">TIDAK MENULARKAN</span>`;
                exp.innerText = "Keringat ataupun gesekan telapak tangan tidak membawa virus. Bersalaman sangat aman.";
                card.classList.add('bg-emerald-500/10', 'border-emerald-500/30');
            } else if (type === 'donor') {
                badge.innerHTML = `<i class="fa-solid fa-triangle-exclamation text-amber-400"></i> <span class="text-amber-400">BERISIKO RENDAH (AMAN KARENA SKRINING)</span>`;
                exp.innerText = "Donor darah di fasilitas resmi menerapkan protokol sterilisasi jarum baru serta uji skrining berlapis ketat.";
                card.classList.add('bg-amber-500/10', 'border-amber-500/30');
            } else if (type === 'jarum') {
                badge.innerHTML = `<i class="fa-solid fa-biohazard text-pink-400"></i> <span class="text-pink-400">BERISIKO TINGGI</span>`;
                exp.innerText = "Darah terinfeksi di dalam rongga jarum langsung masuk menuju pembuluh darah orang lain.";
                card.classList.add('bg-pink-500/10', 'border-pink-500/30');
            } else if (type === 'seks') {
                badge.innerHTML = `<i class="fa-solid fa-biohazard text-pink-400"></i> <span class="text-pink-400">BERISIKO TINGGI</span>`;
                exp.innerText = "Terjadi pertukaran langsung cairan vagina/sperma pada membran mukosa intim.";
                card.classList.add('bg-pink-500/10', 'border-pink-500/30');
            }
            gainXP(10);
        }

        window.toggleChat = function() {
            document.getElementById('chat-window').classList.toggle('hidden');
        }

        // --- ENGINE CHATBOT AI GENERATIF DENGAN PENGETAHUAN FLEKSIBEL LENGKAP ---
        window.sendChatMessage = function() {
            const inputEl = document.getElementById('chat-input-field');
            const msgContainer = document.getElementById('chat-messages-container');
            const rawText = inputEl.value.trim();
            const text = rawText.toLowerCase();
            if (!text) return;

            // Tampilkan pesan pengguna
            const userMsg = document.createElement('div');
            userMsg.className = "bg-indigo-600/30 p-2 rounded-xl text-right ml-auto border border-indigo-500/20 max-w-[85%] text-white text-[11px]";
            userMsg.innerText = rawText;
            msgContainer.appendChild(userMsg);
            inputEl.value = "";
            msgContainer.scrollTop = msgContainer.scrollHeight;

            // Jawaban Otomatis AI Pintar
            setTimeout(() => {
                let reply = "";

                // Logika respons AI cerdas & fleksibel
                if (text.includes("arv") || text.includes("obat")) {
                    reply = "Obat ARV (Antiretroviral) bekerja menekan replikasi virus HIV di dalam darah hingga kadar terendah (Undetectable). ARV harus diminum teratur seumur hidup agar ODHIV tetap hidup sehat dan normal.";
                } else if (text.includes("beda") || text.includes("perbedaan")) {
                    reply = "HIV adalah nama virusnya (Human Immunodeficiency Virus), sedangkan AIDS adalah kumpulan gejala klinis akibat kehancuran sistem imun karena HIV yang tidak diobati.";
                } else if (text.includes("gejala") || text.includes("ciri")) {
                    reply = "Fase awal seringkali tanpa gejala khas (mirip flu biasa). Pada stadium AIDS lanjut, timbul demam berkepanjangan, penurunan berat badan drastis, hingga infeksi oportunistik seperti TBC atau jamur.";
                } else if (text.includes("tular") || text.includes("penularan") || text.includes("sebab")) {
                    reply = "HIV HANYA menular via 4 cairan: Darah, Sperma, Cairan Vagina, dan ASI. Penularan tidak terjadi via udara, makanan, sentuhan, atau gigitan serangga.";
                } else if (text.includes("prep") || text.includes("pep")) {
                    reply = "PrEP adalah obat pencegahan sebelum paparan bagi yang berisiko tinggi. PEP adalah pencegahan darurat pascapaparan yang harus dikonsumsi maksimal 72 jam setelah insiden.";
                } else if (text.includes("cd4") || text.includes("imun")) {
                    reply = "Sel CD4 (T-Helper) adalah jenderal sistem kekebalan tubuh. Virus HIV menyerang dan merusak sel CD4 ini. Angka CD4 normal berkisar 500-1500 sel/µL.";
                } else if (text.includes("u=u") || text.includes("undetectable")) {
                    reply = "U=U artinya 'Undetectable = Untransmittable'. Jika jumlah virus HIV dalam darah sangat rendah hingga tak terdeteksi alat tes, ODHIV TIDAK BISA menularkan virus secara seksual.";
                } else if (text.includes("halo") || text.includes("hi") || text.includes("pagi") || text.includes("siang") || text.includes("malam")) {
                    reply = "Halo! Saya EduYouth Bot AI. Silakan tanyakan apa saja seputar kesehatan, HIV/AIDS, ilmu pengetahuan, atau topik umum lainnya!";
                } else if (text.includes("siapa") || text.includes("nama")) {
                    reply = "Saya adalah EduYouth Bot AI, asisten edukasi pintar yang dirancang untuk membantumu belajar sains dan isu kesehatan remaja secara menyenangkan!";
                } else if (text.includes("terima kasih") || text.includes("makasih") || text.includes("thanks")) {
                    reply = "Sama-sama! Senang bisa membantumu. Jangan ragu untuk bertanya lagi ya!";
                } else {
                    // Respons generatif umum cerdas untuk pertanyaan di luar HIV/AIDS
                    reply = `Mengenai pertanyaanmu tentang *"<sup>${rawText}</sup>"*: Saya adalah AI yang siap membantu! Secara umum, topik ini berhubungan dengan wawasan luas. Jika ada hal spesifik atau kaitannya dengan kesehatan & sains yang ingin kamu gali lebih jauh, beritahu saya ya!`;
                }

                const botMsg = document.createElement('div');
                botMsg.className = "bg-slate-900 p-2.5 rounded-xl border border-slate-700 text-slate-300 mr-auto max-w-[85%] leading-relaxed";
                botMsg.innerHTML = `🤖 ${reply}`;
                msgContainer.appendChild(botMsg);
                msgContainer.scrollTop = msgContainer.scrollHeight;
            }, 350);
        }

        window.showSection = function(sectionId) {
            document.getElementById('auth-section').classList.add('hidden');
            document.getElementById('home-section').classList.add('hidden');
            document.getElementById('belajar-section').classList.add('hidden');
            document.getElementById('fakta-section').classList.add('hidden');
            document.getElementById('quiz-section').classList.add('hidden');
            document.getElementById('result-section').classList.add('hidden');
            document.getElementById('vct-section').classList.add('hidden');
            document.getElementById('simulasi-section').classList.add('hidden');

            document.getElementById(`${sectionId}-section`).classList.remove('hidden');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        window.switchTab = function(tabId) {
            document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('bg-indigo-600', 'text-white');
                btn.classList.add('text-slate-400');
            });
            document.getElementById(`tab-${tabId}`).classList.remove('hidden');
            event.target.classList.add('bg-indigo-600', 'text-white');
            event.target.classList.remove('text-slate-400');
            gainXP(15);
        }

        function gainXP(amount) {
            currentXP += amount;
            document.getElementById('user-xp').innerText = `${currentXP} XP`;
            if (currentXP >= 300) userBadge = "Immune Overlord 👑";
            else if (currentXP >= 180) userBadge = "Virus Crusher ⚡";
            else if (currentXP >= 80) userBadge = "Immune Guardian 🛡️";
            document.getElementById('user-badge').innerText = userBadge;
        }

        // --- FAKTA VS MITOS LOGIC (DENGAN PROTEKSI 1X JAWAB) ---
        window.startFaktaMitos = function() {
            testMode = "fakta"; currentIndex = 0; score = 0;
            showSection('fakta'); renderFaktaQuestion();
        }

        function renderFaktaQuestion() {
            document.getElementById('fakta-feedback').classList.add('hidden');
            
            // Mengaktifkan kembali tombol pilihan untuk soal baru
            const btnTrue = document.getElementById('btn-fakta-true');
            const btnFalse = document.getElementById('btn-fakta-false');
            btnTrue.disabled = false;
            btnFalse.disabled = false;

            const currentQ = faktaMitosData[currentIndex];
            document.getElementById('fakta-progress').innerText = `Soal ${currentIndex + 1} dari 10`;
            document.getElementById('fakta-bar').style.width = `${(currentIndex + 1) * 10}%`;
            document.getElementById('fakta-question-text').innerHTML = `"${currentQ.q}"`;
        }

        window.checkFakta = function(userAnswer) {
            // DIBLOKIR: Matikan tombol fakta dan mitos seketika agar tidak bisa diubah lagi
            document.getElementById('btn-fakta-true').disabled = true;
            document.getElementById('btn-fakta-false').disabled = true;

            const currentQ = faktaMitosData[currentIndex];
            const isCorrect = (userAnswer === currentQ.isFakta);
            const feedbackEl = document.getElementById('fakta-feedback');
            const statusTitleEl = document.getElementById('fakta-status-title');
            feedbackEl.classList.remove('hidden', 'bg-emerald-500/10', 'border-emerald-500/30', 'bg-pink-500/10', 'border-pink-500/30');
            
            if (isCorrect) {
                score++; gainXP(20);
                statusTitleEl.innerHTML = `<i class="fa-solid fa-circle-check text-emerald-400"></i> <span class="text-emerald-400">Jawaban Kamu BENAR! (+20 XP)</span>`;
                feedbackEl.classList.add('bg-emerald-500/10', 'border-emerald-500/30');
            } else {
                statusTitleEl.innerHTML = `<i class="fa-solid fa-circle-xmark text-pink-400"></i> <span class="text-pink-400">Kurang Tepat, Penjelasan Ilmiahnya:</span>`;
                feedbackEl.classList.add('bg-pink-500/10', 'border-pink-500/30');
            }
            document.getElementById('fakta-explanation').innerHTML = currentQ.exp;
        }

        window.nextFakta = function() {
            currentIndex++;
            if (currentIndex < faktaMitosData.length) { renderFaktaQuestion(); } 
            else { finishAssessment("Fakta vs Mitos"); }
        }

        // --- KUIS / PRE-TEST / POST-TEST LOGIC (DENGAN PROTEKSI 1X JAWAB) ---
        window.startQuiz = function() {
            testMode = "quiz";
            document.getElementById('quiz-badge-type').innerHTML = `Aktivitas: <b class="text-pink-400">Kuis Evaluasi</b>`;
            initQuizBuild();
        }

        window.startTest = function(type) {
            testMode = type;
            document.getElementById('quiz-badge-type').innerHTML = `Aktivitas: <b class="text-indigo-400">${type === 'pre' ? 'Pre-Test' : 'Post-Test'}</b>`;
            initQuizBuild();
        }

        function initQuizBuild() {
            currentIndex = 0; score = 0;
            showSection('quiz'); renderQuizQuestion();
        }

        function renderQuizQuestion() {
            document.getElementById('quiz-feedback').classList.add('hidden');
            const currentQ = quizData[currentIndex];
            document.getElementById('quiz-progress').innerText = `Soal ${currentIndex + 1} dari 10`;
            document.getElementById('quiz-bar').style.width = `${(currentIndex + 1) * 10}%`;
            document.getElementById('quiz-question-text').innerText = currentQ.q;
            
            const container = document.getElementById('quiz-options-container');
            container.innerHTML = "";
            currentQ.options.forEach((opt, idx) => {
                const btn = document.createElement('button');
                btn.className = "w-full text-left p-3.5 rounded-xl bg-slate-800 hover:bg-slate-700/80 border border-slate-700 text-xs md:text-sm text-slate-200 transition font-medium disabled:opacity-50 disabled:cursor-not-allowed";
                btn.innerText = `${String.fromCharCode(65 + idx)}. ${opt}`;
                btn.onclick = () => checkQuiz(idx);
                container.appendChild(btn);
            });
        }

        function checkQuiz(userAnswerIdx) {
            // DIBLOKIR: Kunci seluruh opsi jawaban kuis agar tidak bisa diubah
            const optionBtns = document.getElementById('quiz-options-container').getElementsByTagName('button');
            for(let btn of optionBtns) { 
                btn.disabled = true; 
            }

            const currentQ = quizData[currentIndex];
            const isCorrect = (userAnswerIdx === currentQ.correct);
            const feedbackEl = document.getElementById('quiz-feedback');
            const statusTitleEl = document.getElementById('quiz-status-title');
            
            feedbackEl.classList.remove('hidden', 'bg-emerald-500/10', 'border-emerald-500/30', 'bg-pink-500/10', 'border-pink-500/30');

            if (isCorrect) {
                score++; gainXP(25);
                statusTitleEl.innerHTML = `<i class="fa-solid fa-circle-check text-emerald-400"></i> <span class="text-emerald-400">Tepat Sekali! (+25 XP)</span>`;
                feedbackEl.classList.add('bg-emerald-500/10', 'border-emerald-500/30');
            } else {
                statusTitleEl.innerHTML = `<i class="fa-solid fa-circle-xmark text-pink-400"></i> <span class="text-pink-400">Jawaban Salah. Jawaban Benar: Opsi ${String.fromCharCode(65 + currentQ.correct)}</span>`;
                feedbackEl.classList.add('bg-pink-500/10', 'border-pink-500/30');
            }
            document.getElementById('quiz-explanation').innerHTML = currentQ.exp;
        }

        window.nextQuiz = function() {
            currentIndex++;
            if (currentIndex < quizData.length) { renderQuizQuestion(); } 
            else { finishAssessment(testMode === 'pre' ? 'Pre-Test' : (testMode === 'post' ? 'Post-Test' : 'Kuis Kognitif')); }
        }

        function finishAssessment(title) {
            const finalScore = score * 10;
            showSection('result');
            document.getElementById('result-title').innerText = `Hasil ${title}`;
            document.getElementById('result-score').innerText = `${finalScore} / 100`;

            if (testMode === 'pre') {
                dataResponden.skorPretest = finalScore;
                document.getElementById('dash-pre').innerText = finalScore;
                document.getElementById('btn-pretest').classList.add('hidden');
                document.getElementById('btn-posttest').classList.remove('opacity-50', 'cursor-not-allowed');
                document.getElementById('btn-posttest').disabled = false;
                document.getElementById('result-message').innerText = "Pre-Test selesai! Data identitas & nilai awal tersimpan. Yuk pelajari modul edukasi di Menu Belajar sebelum menguji kemampuanmu di Post-Test.";
            } else if (testMode === 'post') {
                dataResponden.skorPosttest = finalScore;
                document.getElementById('dash-post').innerText = finalScore;
                document.getElementById('btn-posttest').classList.add('hidden');
                
                const preScore = dataResponden.skorPretest || 0;
                const gain = finalScore - preScore;
                document.getElementById('dash-gain').innerText = gain >= 0 ? `+${gain} Poin` : `${gain} Poin`;
                document.getElementById('result-message').innerText = `Luar biasa! Seluruh rangkaian tes selesai. Data nilai pre-test, post-test, serta efektivitas belajar kamu telah terkirim otomatis secara aman ke Cloud Database.`;
                
                kirimDataKeFirebase(preScore, finalScore);
            } else {
                document.getElementById('result-message').innerText = "Kuis mandiri selesai! Kamu hebat sudah menyelesaikan tantangan wawasan tingkat lanjut ini. Pertahankan prestasimu!";
            }
        }
    </script>
